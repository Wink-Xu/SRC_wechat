/* components/cover-adjuster/cover-adjuster.wxss */
.adjuster-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #000000;
  z-index: 1000;
  display: flex;
  flex-direction: column;
}

/* 头部 - 最高层级 */
.adjuster-header {
  position: relative;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  padding-top: calc(24rpx + env(safe-area-inset-top));
  background: #000000;
}

.header-btn {
  padding: 10rpx 20rpx;
}

.header-btn text {
  font-size: 30rpx;
  color: #888888;
}

.header-btn.primary text {
  color: #FFFFFF;
  font-weight: 600;
}

.header-title text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* 内容区 */
.adjuster-body {
  flex: 1;
  position: relative;
  overflow: visible;
}

.move-area {
  position: absolute;
  left: -300px;
  top: -300px;
  z-index: 1;
}

.move-view {
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-img {
  width: 100%;
  height: 100%;
}

/* 裁剪框 - 位置通过 JS 动态设置 */
.crop-frame {
  position: absolute;
  left: 20px;
  right: 20px;
  border: 2px solid #FFFFFF;
  border-radius: 6px;
  pointer-events: none;
  z-index: 10;
}

/* 底部 - 最高层级 */
.adjuster-footer {
  position: relative;
  z-index: 100;
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  text-align: center;
  background: #000000;
}

.adjuster-footer text {
  font-size: 26rpx;
  color: #666666;
}