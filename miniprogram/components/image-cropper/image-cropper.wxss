/* components/image-cropper/image-cropper.wxss */
.cropper-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #000000;
  z-index: 1000;
  display: flex;
  flex-direction: column;
}

.cropper-body {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.cropper-image {
  display: block;
}

.crop-box {
  position: absolute;
  border: 2rpx solid #FFFFFF;
  z-index: 10;
}

.crop-border {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border: 2rpx solid #FFFFFF;
}

.crop-handle {
  position: absolute;
  right: -20rpx;
  bottom: -20rpx;
  width: 40rpx;
  height: 40rpx;
  background: #FFFFFF;
  border-radius: 50%;
}

.crop-handle::before {
  content: '';
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  width: 16rpx;
  height: 16rpx;
  border-right: 4rpx solid #1A1A1A;
  border-bottom: 4rpx solid #1A1A1A;
}

.crop-mask {
  position: absolute;
  background: rgba(0, 0, 0, 0.6);
  pointer-events: none;
}

.crop-mask.top {
  top: 0;
  left: 0;
  right: 0;
}

.crop-mask.bottom {
  left: 0;
  right: 0;
  bottom: 0;
}

.crop-mask.left {
  left: 0;
}

.crop-mask.right {
  right: 0;
}

.cropper-actions {
  padding: 40rpx 60rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.action-btn {
  padding: 20rpx 40rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 8rpx;
}

.action-btn text {
  color: #FFFFFF;
  font-size: 32rpx;
}

.action-btn.primary {
  background: #1A1A1A;
}

.action-tips text {
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
}