/* app.wxss - 全局样式 - On Running 极简风格 */

/* 主题变量 - 瑞士极简黑白配色 */
page {
  --primary: #000000;
  --primary-dark: #333333;
  --secondary: #666666;
  --secondary-light: #999999;
  --accent: #E0E0E0;
  --background: #FFFFFF;
  --surface: #F8F9FA;
  --text-primary: #000000;
  --text-secondary: #666666;
  --text-hint: #999999;
  --divider: #E0E0E0;
  --error: #000000;
  --success: #2E7D32;
  --warning: #CC7722;

  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'Helvetica', 'Arial', sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--background);
  box-sizing: border-box;
  line-height: 1.5;
}

/* 通用容器 */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: var(--background);
}

/* 页面内容 */
.page-content {
  flex: 1;
  padding: 0;
}

/* 卡片样式 - 极简风格 */
.card {
  background-color: var(--background);
  border-radius: 12rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--divider);
  box-shadow: none;
}

.card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  letter-spacing: -0.5rpx;
}

/* 按钮样式 - 瑞士风格 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: -0.3rpx;
  transition: all 0.2s ease;
}

.btn-primary {
  background-color: var(--primary);
  color: var(--background);
  border: none;
}

.btn-primary:active {
  background-color: var(--primary-dark);
  opacity: 0.9;
}

.btn-secondary {
  background-color: var(--background);
  color: var(--primary);
  border: 2rpx solid var(--primary);
}

.btn-secondary:active {
  background-color: var(--surface);
}

.btn-disabled {
  background-color: var(--accent);
  color: var(--secondary-light);
}

.btn-small {
  height: 64rpx;
  padding: 0 28rpx;
  font-size: 26rpx;
  border-radius: 8rpx;
}

.btn-full {
  width: 100%;
}

/* 输入框样式 */
.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input {
  height: 96rpx;
  padding: 0 28rpx;
  background-color: var(--surface);
  border-radius: 8rpx;
  font-size: 30rpx;
  border: 1rpx solid transparent;
}

.input:focus {
  background-color: var(--background);
  border-color: var(--primary);
}

.input-placeholder {
  color: var(--text-hint);
}

/* 列表项样式 */
.list-item {
  display: flex;
  align-items: center;
  padding: 32rpx 24rpx;
  background-color: var(--background);
  border-bottom: 1rpx solid var(--divider);
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 24rpx;
}

.list-item-content {
  flex: 1;
}

.list-item-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.list-item-desc {
  font-size: 26rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}

.list-item-arrow {
  width: 24rpx;
  height: 24rpx;
  color: var(--text-hint);
}

/* 标签样式 - 极简设计 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.3rpx;
}

.tag-primary {
  background-color: var(--primary);
  color: var(--background);
}

.tag-warning {
  background-color: #F5F5F0;
  color: var(--warning);
  border: 1rpx solid #E5E5E0;
}

.tag-error {
  background-color: #FDF5F5;
  color: var(--error);
  border: 1rpx solid #F0E5E5;
}

.tag-success {
  background-color: #F5F9F5;
  color: var(--success);
  border: 1rpx solid #E5F0E5;
}

.tag-secondary {
  background-color: var(--surface);
  color: var(--text-secondary);
  border: 1rpx solid var(--divider);
}

/* 状态指示器 */
.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.status-dot-success {
  background-color: var(--success);
}

.status-dot-warning {
  background-color: var(--warning);
}

.status-dot-error {
  background-color: var(--error);
}

/* 积分显示 */
.points-display {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--primary);
  letter-spacing: -1rpx;
}

.points-unit {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-left: 8rpx;
  font-weight: 400;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 40rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: var(--divider);
  margin: 32rpx 0;
}

/* Flex 工具类 */
.flex {
  display: flex;
}

.flex-column {
  flex-direction: column;
}

.flex-center {
  align-items: center;
  justify-content: center;
}

.flex-between {
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

/* 间距工具类 */
.mt-20 { margin-top: 20rpx; }
.mb-20 { margin-bottom: 20rpx; }
.ml-20 { margin-left: 20rpx; }
.mr-20 { margin-right: 20rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-32 { margin-bottom: 32rpx; }
.ml-32 { margin-left: 32rpx; }
.mr-32 { margin-right: 32rpx; }
.p-20 { padding: 20rpx; }
.p-32 { padding: 32rpx; }

/* 文字工具类 */
.text-center { text-align: center; }
.text-bold { font-weight: 600; }
.text-primary { color: var(--primary); }
.text-secondary { color: var(--text-secondary); }
.text-hint { color: var(--text-hint); }
.text-error { color: var(--error); }

/* 字重工具类 */
.font-light { font-weight: 300; }
.font-regular { font-weight: 400; }
.font-medium { font-weight: 500; }
.font-semibold { font-weight: 600; }
.font-bold { font-weight: 700; }
.font-extrabold { font-weight: 800; }
