/* app.wxss - 全局样式 */

/* 主题变量 */
page {
  --primary-color: #9C27B0;
  --primary-dark: #7B1FA2;
  --primary-light: #E1BEE7;
  --accent-color: #FF4081;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --divider-color: #EEEEEE;
  --background-color: #F5F5F5;
  --white: #FFFFFF;
  --error-color: #F44336;
  --success-color: #9C27B0;
  --warning-color: #FF9800;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--background-color);
  box-sizing: border-box;
}

/* 通用容器 */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: var(--background-color);
}

/* 页面内容 */
.page-content {
  flex: 1;
  padding: 20rpx;
}

/* 卡片样式 */
.card {
  background-color: var(--white);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

/* 按钮样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-primary {
  background-color: var(--primary-color);
  color: var(--white);
}

.btn-primary:active {
  background-color: var(--primary-dark);
}

.btn-secondary {
  background-color: var(--white);
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
}

.btn-disabled {
  background-color: var(--text-hint);
  color: var(--white);
}

.btn-small {
  height: 60rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  border-radius: 30rpx;
}

.btn-full {
  width: 100%;
}

/* 输入框样式 */
.input-group {
  margin-bottom: 24rpx;
}

.input-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.input {
  height: 88rpx;
  padding: 0 24rpx;
  background-color: var(--background-color);
  border-radius: 12rpx;
  font-size: 30rpx;
}

.input-placeholder {
  color: var(--text-hint);
}

/* 列表项样式 */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: var(--white);
  border-bottom: 1rpx solid var(--divider-color);
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 24rpx;
}

.list-item-content {
  flex: 1;
}

.list-item-title {
  font-size: 30rpx;
  color: var(--text-primary);
}

.list-item-desc {
  font-size: 26rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}

.list-item-arrow {
  width: 24rpx;
  height: 24rpx;
  color: var(--text-hint);
}

/* 标签样式 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.tag-primary {
  background-color: var(--primary-light);
  color: var(--primary-dark);
}

.tag-warning {
  background-color: #FFF3E0;
  color: #E65100;
}

.tag-error {
  background-color: #FFEBEE;
  color: #C62828;
}

.tag-success {
  background-color: #E8F5E9;
  color: #2E7D32;
}

/* 状态指示器 */
.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.status-dot-success {
  background-color: var(--success-color);
}

.status-dot-warning {
  background-color: var(--warning-color);
}

.status-dot-error {
  background-color: var(--error-color);
}

/* 积分显示 */
.points-display {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--accent-color);
}

.points-unit {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-left: 8rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: var(--divider-color);
  margin: 24rpx 0;
}

/* Flex 工具类 */
.flex {
  display: flex;
}

.flex-column {
  flex-direction: column;
}

.flex-center {
  align-items: center;
  justify-content: center;
}

.flex-between {
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

/* 间距工具类 */
.mt-20 {
  margin-top: 20rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.ml-20 {
  margin-left: 20rpx;
}

.mr-20 {
  margin-right: 20rpx;
}

.p-20 {
  padding: 20rpx;
}

/* 文字工具类 */
.text-center {
  text-align: center;
}

.text-bold {
  font-weight: 600;
}

.text-primary {
  color: var(--primary-color);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-hint {
  color: var(--text-hint);
}

.text-error {
  color: var(--error-color);
}