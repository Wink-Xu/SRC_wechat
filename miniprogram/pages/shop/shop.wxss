/* pages/shop/shop.wxss - On Running 极简风格 */

.container {
  min-height: 100vh;
  background: var(--background);
}

/* 头部 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #F0F0F0;
}

.header-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #1A1A1A;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.header-action {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666666;
}

.header-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 8rpx;
}

/* 商品列表 */
.product-list {
  padding: 30rpx;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.product-card {
  background: #FFFFFF;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #F0F0F0;
}

.product-image {
  width: 100%;
  height: 300rpx;
  background: #F5F5F5;
}

.product-info {
  padding: 20rpx;
}

.product-name {
  font-size: 28rpx;
  color: #1A1A1A;
  display: block;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
}

.product-price {
  margin-bottom: 8rpx;
}

.points-price {
  display: inline-flex;
  align-items: baseline;
}

.points-price .price-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.points-price .price-unit {
  font-size: 22rpx;
  color: #666666;
  margin-left: 4rpx;
}

.cash-price {
  display: inline-flex;
  align-items: baseline;
  margin-left: 12rpx;
}

.cash-price .price-label {
  font-size: 22rpx;
  color: #999999;
  margin-right: 4rpx;
}

.cash-price .price-value {
  font-size: 26rpx;
  color: #666666;
}

.product-stock {
  font-size: 22rpx;
  color: #999999;
}

/* 加载状态 */
.loading-box,
.loading-more {
  text-align: center;
  padding: 40rpx;
  color: #999999;
}

.no-more {
  text-align: center;
  padding: 30rpx;
  color: #999999;
  font-size: 24rpx;
}

.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  color: #999999;
  font-size: 28rpx;
}
