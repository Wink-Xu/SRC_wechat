/* pages/shop/shop.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 头部 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: #fff;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.header-action {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
}

.header-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 8rpx;
}

/* 商品列表 */
.product-list {
  padding: 20rpx;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.product-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 300rpx;
}

.product-info {
  padding: 20rpx;
}

.product-name {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-price {
  margin-bottom: 8rpx;
}

.points-price {
  display: inline-flex;
  align-items: baseline;
}

.points-price .price-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF9800;
}

.points-price .price-unit {
  font-size: 22rpx;
  color: #FF9800;
  margin-left: 4rpx;
}

.cash-price {
  display: inline-flex;
  align-items: baseline;
  margin-left: 12rpx;
}

.cash-price .price-label {
  font-size: 22rpx;
  color: #999;
  margin-right: 4rpx;
}

.cash-price .price-value {
  font-size: 26rpx;
  color: #666;
}

.product-stock {
  font-size: 22rpx;
  color: #999;
}

/* 加载状态 */
.loading-box,
.loading-more {
  text-align: center;
  padding: 40rpx;
  color: #999;
}

.no-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 24rpx;
}

.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  color: #999;
}