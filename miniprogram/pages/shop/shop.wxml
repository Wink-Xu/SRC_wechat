<!--pages/shop/shop.wxml-->
<view class="container">
  <!-- 头部 -->
  <view class="header">
    <text class="header-title">周边商城</text>
    <view class="header-action" bindtap="goToOrders">
      <image class="header-icon" src="/images/order.png"></image>
      <text>我的订单</text>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="product-list">
    <view wx:if="{{loading && products.length === 0}}" class="loading-box">
      <text>加载中...</text>
    </view>

    <view wx:elif="{{products.length === 0}}" class="empty-box">
      <image class="empty-icon" src="/images/empty.png"></image>
      <text class="empty-text">暂无商品</text>
    </view>

    <view class="product-grid">
      <view
        class="product-card"
        wx:for="{{products}}"
        wx:key="_id"
        bindtap="goToDetail"
        data-id="{{item._id}}"
      >
        <image class="product-image" src="{{item.displayImages[0] || item.images[0] || item.displayImage || item.image || '/images/default-product.png'}}" mode="aspectFill"></image>
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <view class="product-price">
            <view wx:if="{{item.points_price}}" class="points-price">
              <text class="price-value">{{item.points_price}}</text>
              <text class="price-unit">积分</text>
            </view>
            <view wx:if="{{item.cash_price}}" class="cash-price">
              <text class="price-label">或</text>
              <text class="price-value">¥{{item.cashPriceYuan}}</text>
            </view>
          </view>
          <text class="product-stock">库存: {{item.stock}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{loadingMore}}" class="loading-more">
      <text>加载更多...</text>
    </view>

    <view wx:if="{{!hasMore && products.length > 0}}" class="no-more">
      <text>没有更多了</text>
    </view>
  </view>
</view>