/* pages/index/index.wxss */

.container {
  padding-bottom: 40rpx;
}

/* 头部区域 */
.header {
  background: linear-gradient(135deg, #9C27B0, #7B1FA2);
  padding: 40rpx 30rpx;
  color: #fff;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.user-text {
  flex: 1;
  margin-left: 24rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  display: block;
}

.status-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-top: 8rpx;
  background: rgba(255, 255, 255, 0.2);
}

.status-tag.member {
  background: rgba(255, 255, 255, 0.3);
}

.status-tag.pending {
  background: rgba(255, 152, 0, 0.5);
}

.points-box {
  text-align: center;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
}

.points-label {
  font-size: 22rpx;
  opacity: 0.8;
  display: block;
}

.points-value {
  font-size: 40rpx;
  font-weight: 700;
}

.login-prompt {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
}

.prompt-text {
  font-size: 30rpx;
}

/* 快捷入口 */
.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 30rpx;
  margin-top: -20rpx;
  position: relative;
  z-index: 10;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 26rpx;
  color: #666;
}

/* 区域 */
.section {
  padding: 20rpx 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-more {
  font-size: 26rpx;
  color: #999;
}

/* 活动列表 */
.activity-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.activity-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.activity-item:last-child {
  border-bottom: none;
}

.activity-info {
  flex: 1;
}

.activity-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.activity-meta {
  display: flex;
  gap: 20rpx;
}

.activity-time,
.activity-location {
  font-size: 24rpx;
  color: #999;
}

.activity-points {
  text-align: center;
  padding: 12rpx 20rpx;
  background: #FFF8E1;
  border-radius: 12rpx;
}

.activity-points .points-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF9800;
  display: block;
}

.activity-points .points-label {
  font-size: 20rpx;
  color: #999;
}

/* 加载状态 */
.loading-box {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60rpx;
  background: #fff;
  border-radius: 16rpx;
}

.empty-text {
  color: #999;
}