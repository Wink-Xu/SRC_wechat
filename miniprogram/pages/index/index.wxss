/* pages/index/index.wxss - On Running 极简风格 */

.container {
  padding-bottom: 40rpx;
}

/* 头部区域 - 极简白色背景 */
.header {
  background: #FFFFFF;
  padding: 40rpx 30rpx;
  color: #000000;
  border-bottom: 1rpx solid #F0F0F0;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 2rpx solid #E0E0E0;
}

.user-text {
  flex: 1;
  margin-left: 24rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  color: #000000;
}

.status-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-top: 8rpx;
  background: #F5F5F5;
  color: #666666;
}

.status-tag.member {
  background: #000000;
  color: #FFFFFF;
}

.status-tag.pending {
  background: #F5F5F0;
  color: #CC7722;
}

.points-box {
  text-align: center;
  padding: 16rpx 24rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  margin-top: 16rpx;
}

.points-label {
  font-size: 22rpx;
  color: #999999;
  display: block;
}

.points-value {
  font-size: 40rpx;
  font-weight: 800;
  color: #000000;
}

.login-prompt {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
}

.prompt-text {
  font-size: 30rpx;
  color: #000000;
}

/* 快捷入口 */
.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 30rpx;
  margin-top: 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 26rpx;
  color: #666666;
}

/* 区域 */
.section {
  padding: 20rpx 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #000000;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.section-more {
  font-size: 26rpx;
  color: #999999;
}

/* 活动列表 */
.activity-list {
  background: #FFFFFF;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #F0F0F0;
}

.activity-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.activity-item:last-child {
  border-bottom: none;
}

.activity-info {
  flex: 1;
}

.activity-title {
  font-size: 30rpx;
  color: #000000;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.activity-meta {
  display: flex;
  gap: 20rpx;
}

.activity-time,
.activity-location {
  font-size: 24rpx;
  color: #999999;
}

.activity-points {
  text-align: center;
  padding: 12rpx 20rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
}

.activity-points .points-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #000000;
  display: block;
}

.activity-points .points-label {
  font-size: 20rpx;
  color: #999999;
}

/* 加载状态 */
.loading-box {
  text-align: center;
  padding: 60rpx;
  color: #999999;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  border: 1rpx solid #F0F0F0;
}

.empty-text {
  color: #999999;
}
