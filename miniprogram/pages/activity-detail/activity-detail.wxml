<!--pages/activity-detail/activity-detail.wxml-->
<view class="container">
  <view wx:if="{{loading}}" class="loading-box">
    <text>加载中...</text>
  </view>

  <!-- 非团员查看往期活动提示 -->
  <block wx:elif="{{activity && activity.status === 'ended' && !isMember}}">
    <view class="permission-denied">
      <text class="denied-icon">🔒</text>
      <text class="denied-title">仅团员可查看</text>
      <text class="denied-desc">成为团员后可查看往期活动详情</text>
      <button class="btn-apply" bindtap="goToApply">申请入团</button>
    </view>
  </block>

  <block wx:elif="{{activity}}">
    <!-- 正在报名的活动：显示完整信息 -->
    <block wx:if="{{activity.status === 'published' || activity.status === 'ongoing'}}">
      <!-- 封面图头部 -->
      <view class="cover-header">
        <image class="cover-image" src="{{activity.cover_image || '/images/default-product.png'}}" mode="aspectFill"></image>
        <view class="cover-content">
          <view class="points-tag">
            <text class="points-value">+{{activity.points}}</text>
            <text class="points-label">积分</text>
          </view>
          <text class="activity-title">{{activity.title}}</text>
        </view>
      </view>

      <!-- 活动信息列表 -->
      <view class="info-grid">
        <view class="info-cell">
          <text class="info-label">活动时间</text>
          <text class="info-value">{{activity.formattedTime}}</text>
        </view>
        <view class="info-cell">
          <text class="info-label">集合地点</text>
          <text class="info-value">{{activity.location}}</text>
        </view>
        <view class="info-cell">
          <text class="info-label">跑步类型</text>
          <text class="info-value">{{runTypeText}}</text>
        </view>
        <view class="info-cell" wx:if="{{activity.registration_deadline}}">
          <text class="info-label">报名截止</text>
          <text class="info-value">{{activity.formattedRegistrationDeadline}}</text>
        </view>
        <view class="info-cell" wx:if="{{activity.dress_code}}">
          <text class="info-label">DressCode</text>
          <text class="info-value">{{activity.dress_code}}</text>
        </view>
        <view class="info-cell">
          <text class="info-label">报名人数</text>
          <text class="info-value"><text class="highlight">{{activity.registered_count || 0}}</text>/{{activity.quota}}人</text>
        </view>
      </view>

      <!-- 活动详情 -->
      <view class="section-card">
        <view class="card-header-simple">
          <text class="card-title">活动详情</text>
        </view>
        <text class="desc-text">{{activity.description}}</text>
      </view>

      <!-- 已报名团员 -->
      <view class="section-card">
        <view class="card-header-simple">
          <text class="card-title">已报名</text>
          <view class="view-all-btn" bindtap="viewParticipants" wx:if="{{participants.length > 0}}">
            <text>全部 {{activity.registered_count || 0}}人</text>
            <image class="arrow-icon" src="/images/arrow-right.png"></image>
          </view>
        </view>
        <view class="participants-list" wx:if="{{participants.length > 0}}">
          <view class="participant-item" wx:for="{{participants}}" wx:for-limit="6" wx:key="_id">
            <image class="participant-avatar" src="{{item.avatar || '/images/default-avatar.png'}}"></image>
            <text class="participant-name">{{item.nickname}}</text>
            <text class="status-dot {{item.status === 'checked_in' ? 'checked-in' : ''}}" wx:if="{{item.status}}"></text>
          </view>
        </view>
        <view class="no-participants" wx:else>
          <text>暂无团员报名</text>
        </view>
      </view>

      <!-- 底部操作区 -->
      <view class="footer-actions">
        <!-- 未报名用户显示报名按钮 -->
        <block wx:if="{{!isRegistered}}">
          <button class="btn-register" bindtap="handleRegister">立即报名</button>
        </block>

        <!-- 已报名用户显示取消报名按钮 -->
        <block wx:elif="{{isRegistered && registration.check_in_status !== 'checked_in'}}">
          <button class="btn-cancel-register" bindtap="handleCancelRegistration">取消报名</button>
        </block>

        <!-- 已签到用户显示已签到标识 -->
        <block wx:if="{{isRegistered && registration.check_in_status === 'checked_in'}}">
          <view class="checked-in-badge">
            <image class="badge-icon" src="/images/check.png"></image>
            <text>已签到</text>
          </view>
        </block>
      </view>
    </block>

    <!-- 往期活动：只显示详情和照片 -->
    <block wx:else>
      <!-- 封面图头部 -->
      <view class="cover-header past-cover">
        <image class="cover-image" src="{{activity.cover_image || '/images/default-product.png'}}" mode="aspectFill"></image>
        <view class="cover-actions" wx:if="{{canUploadPhotos}}">
          <button class="btn-change-cover" bindtap="changeCoverImage">更换封面</button>
        </view>
        <view class="cover-content">
          <text class="activity-title">{{activity.title}}</text>
        </view>
      </view>

      <!-- 活动详情 -->
      <view class="section-card">
        <view class="card-header-simple">
          <text class="card-title">活动详情</text>
        </view>
        <text class="desc-text">{{activity.description}}</text>
      </view>

      <!-- 活动照片 -->
      <view class="section-card">
        <view class="card-header-simple">
          <text class="card-title">活动照片</text>
          <view class="photo-actions">
            <view class="upload-btn" wx:if="{{canUploadPhotos && !isSelectMode}}" bindtap="uploadPhotos">
              <text>上传</text>
            </view>
            <view class="edit-btn" wx:if="{{canUploadPhotos && activity.photos && activity.photos.length > 0 && !isSelectMode}}" bindtap="enterSelectMode">
              <text>编辑</text>
            </view>
            <block wx:if="{{isSelectMode}}">
              <view class="select-btns">
                <text class="select-btn" bindtap="selectAll">全选</text>
                <text class="select-btn" bindtap="cancelSelectMode">取消</text>
                <text class="select-btn delete" bindtap="deleteSelectedPhotos" wx:if="{{selectedPhotos.length > 0}}">删除({{selectedPhotos.length}})</text>
              </view>
            </block>
          </view>
        </view>
        <view class="photos-grid" wx:if="{{activity.photos && activity.photos.length > 0}}">
          <view
            class="photo-item {{isSelectMode && selectedPhotos.includes(index) ? 'selected' : ''}}"
            wx:for="{{activity.photos}}"
            wx:key="*this"
          >
            <image class="photo-img" src="{{item}}" mode="aspectFill" bindtap="{{isSelectMode ? 'toggleSelectPhoto' : 'previewImage'}}" data-index="{{index}}"></image>
            <view class="photo-delete" wx:if="{{canUploadPhotos && !isSelectMode}}" bindtap="deletePhoto" data-index="{{index}}">
              <text>×</text>
            </view>
            <view class="photo-check" wx:if="{{isSelectMode && selectedPhotos.includes(index)}}">
              <text>✓</text>
            </view>
          </view>
        </view>
        <view class="no-photos" wx:else>
          <text>暂无照片</text>
        </view>
      </view>
    </block>
  </block>
</view>