<!--pages/activity-detail/activity-detail.wxml-->
<view class="container">
  <view wx:if="{{loading}}" class="loading-box">
    <text>加载中...</text>
  </view>

  <block wx:elif="{{activity}}">
    <!-- 正在报名的活动：显示完整信息 -->
    <block wx:if="{{activity.status === 'published' || activity.status === 'ongoing'}}">
      <!-- 封面图头部 -->
      <view class="cover-header">
        <image class="cover-image" src="/images/default-product.png" mode="aspectFill"></image>
        <view class="cover-overlay"></view>
        <view class="cover-content">
          <view class="status-tag {{activity.statusClass}}">{{activity.statusText}}</view>
          <text class="activity-title">{{activity.title}}</text>
          <view class="points-tag">
            <text class="points-value">+{{activity.points}}</text>
            <text class="points-label">积分</text>
          </view>
        </view>
      </view>

      <!-- 活动信息网格 -->
      <view class="info-grid">
        <view class="info-cell">
          <image class="info-icon" src="/images/time.png"></image>
          <text class="info-label">活动时间</text>
          <text class="info-value">{{activity.formattedTime}}</text>
        </view>
        <view class="info-cell">
          <image class="info-icon" src="/images/location.png"></image>
          <text class="info-label">集合地点</text>
          <text class="info-value">{{activity.location}}</text>
        </view>
        <view class="info-cell">
          <image class="info-icon" src="/images/user.png"></image>
          <text class="info-label">跑步类型</text>
          <text class="info-value">{{runTypeText}}</text>
        </view>
        <view class="info-cell">
          <image class="info-icon" src="/images/user.png"></image>
          <text class="info-label">报名人数</text>
          <text class="info-value">
            <text class="highlight">{{activity.registered_count || 0}}</text>
            <text>/{{activity.quota}}人</text>
          </text>
        </view>
      </view>

      <!-- 活动详情 -->
      <view class="section-card">
        <view class="card-header-simple">
          <text class="card-title">活动详情</text>
        </view>
        <text class="desc-text">{{activity.description}}</text>
      </view>

      <!-- 补充信息 -->
      <view class="section-card" wx:if="{{activity.dress_code}}">
        <view class="card-header-simple">
          <text class="card-title">Dress Code</text>
        </view>
        <text class="desc-text">{{activity.dress_code}}</text>
      </view>

      <view class="section-card" wx:if="{{activity.registration_deadline}}">
        <view class="card-header-simple">
          <text class="card-title">报名截止</text>
        </view>
        <text class="desc-text highlight-text">{{activity.registration_deadline}}</text>
      </view>

      <!-- 已报名团员 -->
      <view class="section-card">
        <view class="card-header-simple">
          <text class="card-title">已报名团员</text>
          <view class="view-all-btn" bindtap="viewParticipants">
            <text>查看全部 {{activity.registered_count || 0}}人</text>
            <image class="arrow-icon" src="/images/arrow-right.png"></image>
          </view>
        </view>
        <view class="participants-list" wx:if="{{participants.length > 0}}">
          <view class="participant-item" wx:for="{{participants}}" wx:for-limit="5" wx:key="_id">
            <image class="participant-avatar" src="{{item.avatar || '/images/default-avatar.png'}}"></image>
            <text class="participant-name">{{item.nickname}}</text>
            <text class="status-dot {{item.status === 'checked_in' ? 'checked-in' : ''}}" wx:if="{{item.status}}"></text>
          </view>
        </view>
        <view class="no-participants" wx:else>
          <text>暂无团员报名</text>
        </view>
      </view>

      <!-- 底部操作区 -->
      <view class="footer-actions">
        <!-- 管理员查看签到码按钮（ongoing 状态） -->
        <view wx:if="{{isAdminOrLeader && activity.status === 'ongoing'}}" class="admin-actions">
          <button class="btn btn-secondary btn-small" bindtap="showCheckInQrCode">
            查看签到码
          </button>
          <text class="checkin-count">已签到：{{checkInCount}}人</text>
        </view>

        <!-- 已签到用户显示已签到标识 -->
        <block wx:elif="{{isRegistered && registration.check_in_status === 'checked_in'}}">
          <view class="checked-in-badge">
            <image class="badge-icon" src="/images/check.png"></image>
            <text>已签到</text>
          </view>
        </block>

        <!-- 未签到用户显示提示 -->
        <block wx:elif="{{isRegistered && activity.status === 'ongoing'}}">
          <view class="checkin-hint-box">
            <text class="checkin-hint">请使用微信"扫一扫"扫描签到码</text>
          </view>
        </block>
      </view>
    </block>

    <!-- 往期活动：只显示详情和照片 -->
    <block wx:else>
      <!-- 封面图头部 -->
      <view class="cover-header">
        <image class="cover-image" src="{{activity.cover_image || '/images/default-product.png'}}" mode="aspectFill"></image>
        <view class="cover-overlay"></view>
        <view class="cover-content">
          <view class="status-tag {{activity.statusClass}}">{{activity.statusText}}</view>
          <text class="activity-title">{{activity.title}}</text>
        </view>
      </view>

      <!-- 活动详情 -->
      <view class="section-card">
        <view class="card-header-simple">
          <text class="card-title">活动详情</text>
        </view>
        <text class="desc-text">{{activity.description}}</text>
      </view>

      <!-- 活动照片 -->
      <view class="section-card">
        <view class="card-header-simple">
          <text class="card-title">活动照片</text>
          <view class="upload-btn" wx:if="{{canUploadPhotos}}" bindtap="uploadPhotos">
            <image class="upload-icon" src="/images/add.png"></image>
            <text>上传</text>
          </view>
        </view>
        <view class="photos-grid" wx:if="{{activity.photos && activity.photos.length > 0}}">
          <view
            class="photo-item"
            wx:for="{{activity.photos}}"
            wx:key="*this"
            bindtap="previewImage"
            data-index="{{index}}"
          >
            <image class="photo-img" src="{{item}}" mode="aspectFill"></image>
          </view>
        </view>
        <view class="no-photos" wx:else>
          <text>暂无照片</text>
        </view>
      </view>
    </block>
  </block>

  <!-- 签到码弹窗 -->
  <view class="modal-mask" wx:if="{{showCheckInQr}}" bindtap="closeCheckInQrCode">
    <view class="modal-content" catchtap="noop">
      <view class="modal-header">
        <text class="modal-title">活动签到码</text>
        <text class="modal-close" bindtap="closeCheckInQrCode">×</text>
      </view>
      <view class="modal-body">
        <image class="qr-code-img" src="{{checkInQrCode}}" mode="aspectFit"></image>
        <text class="qr-hint">微信"扫一扫"即可签到</text>
        <view class="qr-actions">
          <button class="btn-save" bindtap="saveQrCode">保存图片</button>
        </view>
        <view class="qr-stats">
          <text>已签到：{{checkInCount}}人</text>
        </view>
      </view>
    </view>
  </view>
</view>