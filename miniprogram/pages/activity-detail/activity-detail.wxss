/* pages/activity-detail/activity-detail.wxss - 简约现代风格 */

page {
  background: #F8F8F8;
}

.container {
  min-height: 100vh;
  background: #F8F8F8;
  padding-bottom: 180rpx;
}

.loading-box {
  text-align: center;
  padding: 120rpx;
  color: #999;
  font-size: 28rpx;
}

/* 非团员查看限制 */
.permission-denied {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
  padding: 60rpx;
}

.denied-icon {
  font-size: 100rpx;
  margin-bottom: 40rpx;
}

.denied-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 16rpx;
}

.denied-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.btn-apply {
  background: #1A1A1A;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 500;
  padding: 24rpx 60rpx;
  border-radius: 48rpx;
  border: none;
}

/* ========== 封面图头部 ========== */
.cover-header {
  position: relative;
  height: 440rpx;
  overflow: hidden;
}

.past-cover {
  height: 360rpx;
}

.cover-actions {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  z-index: 10;
}

.btn-change-cover {
  background: rgba(0, 0, 0, 0.6);
  color: #FFFFFF;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  border: none;
}

.btn-change-cover::after {
  border: none;
}

.cover-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.cover-content {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 70%;
  padding: 20rpx 28rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 16rpx;
}

.activity-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #FFFFFF;
  line-height: 1.4;
  text-shadow: 0 2rpx 16rpx rgba(0,0,0,0.5);
  text-align: right;
  letter-spacing: 1rpx;
}

.points-tag {
  display: inline-flex;
  align-items: baseline;
  background: rgba(255,255,255,0.95);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.points-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.points-label {
  font-size: 20rpx;
  color: #666666;
  margin-left: 4rpx;
}

/* ========== 信息列表 ========== */
.info-grid {
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 8rpx 28rpx;
}

.info-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.info-cell:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #999999;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #1A1A1A;
  font-weight: 500;
  text-align: right;
  flex: 1;
  margin-left: 32rpx;
}

.info-value .highlight {
  color: #1A1A1A;
  font-weight: 700;
  font-size: 32rpx;
}

.location-value {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  color: #1A1A1A;
}

.location-icon {
  font-size: 20rpx;
  color: #999;
  margin-left: 8rpx;
}

/* ========== 活动详情卡片 ========== */
.section-card {
  background: #FFFFFF;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
}

.card-header-simple {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #999999;
  text-transform: lowercase;
  letter-spacing: 2rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 2;
  display: block;
}

/* ========== 已报名团员 ========== */
.participants-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.participant-item {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx 12rpx 12rpx;
  background: #F8F8F8;
  border-radius: 32rpx;
}

.participant-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.participant-name {
  font-size: 26rpx;
  color: #1A1A1A;
  font-weight: 500;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #E0E0E0;
  margin-left: 8rpx;
}

.status-dot.checked-in {
  background: #1A1A1A;
}

.view-all-btn {
  display: flex;
  align-items: center;
  color: #1A1A1A;
  font-size: 24rpx;
  font-weight: 600;
}

.arrow-icon {
  width: 28rpx;
  height: 28rpx;
  margin-left: 4rpx;
}

.no-participants {
  text-align: center;
  padding: 40rpx;
  color: #CCCCCC;
  font-size: 26rpx;
}

/* ========== 照片区域 ========== */
.photo-actions {
  display: flex;
  align-items: center;
}

.upload-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1A1A1A;
  color: #FFFFFF;
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.edit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  color: #1A1A1A;
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  margin-left: 12rpx;
}

.select-btns {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.select-btn {
  font-size: 24rpx;
  color: #1A1A1A;
  padding: 8rpx 12rpx;
}

.select-btn.delete {
  color: #F44336;
  font-weight: 500;
}

.photos-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.photo-item {
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
  background: #F5F5F5;
  position: relative;
}

.photo-item.selected {
  border: 4rpx solid #1A1A1A;
  box-sizing: border-box;
}

.photo-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.photo-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-delete text {
  color: #fff;
  font-size: 28rpx;
  line-height: 1;
}

.photo-check {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  background: #1A1A1A;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-check text {
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
}

.no-photos {
  text-align: center;
  padding: 60rpx 30rpx;
  color: #CCCCCC;
  font-size: 26rpx;
}

/* ========== 底部操作区 ========== */
.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.btn-register {
  width: 100%;
  height: 92rpx;
  background: #1A1A1A;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 46rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 2rpx;
}

.btn-register::after {
  border: none;
}

.btn-cancel-register {
  width: 100%;
  height: 92rpx;
  background: #F5F5F5;
  color: #666666;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 46rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-cancel-register::after {
  border: none;
}

.checked-in-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  background: #F5F5F5;
  border-radius: 46rpx;
  color: #1A1A1A;
  font-size: 30rpx;
  font-weight: 600;
}

.badge-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 12rpx;
}
