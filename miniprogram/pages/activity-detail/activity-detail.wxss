/* pages/activity-detail/activity-detail.wxss - 昂跑风格 */

page {
  background: var(--background);
}

.container {
  min-height: 100vh;
  background: var(--background);
  padding-bottom: 180rpx;
}

.loading-box {
  text-align: center;
  padding: 120rpx;
  color: #999;
}

/* ========== 封面图头部 - 昂跑风格 ========== */
.cover-header {
  position: relative;
  height: 400rpx;
  overflow: hidden;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.cover-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.4) 100%);
}

.cover-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 0 32rpx 28rpx;
}

.status-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  background: #FFFFFF;
  color: #1A1A1A;
}

.status-tag.tag-primary {
  background: #FFFFFF;
  color: #1A1A1A;
}

.status-tag.tag-success {
  background: #FFFFFF;
  color: #1A1A1A;
}

.status-tag.tag-warning {
  background: #FFFFFF;
  color: #1A1A1A;
}

.status-tag.tag-error {
  background: #FFFFFF;
  color: #1A1A1A;
}

.status-tag.tag-secondary {
  background: #FFFFFF;
  color: #666666;
}

.activity-title {
  display: block;
  font-size: 40rpx;
  font-weight: 500;
  color: #fff;
  line-height: 1.3;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

.points-tag {
  display: inline-flex;
  align-items: baseline;
  background: rgba(255,255,255,0.9);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.points-value {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.points-label {
  font-size: 22rpx;
  color: #666666;
  margin-left: 4rpx;
}

/* ========== 信息网格 - 横向列表 ========== */
.info-grid {
  display: flex;
  flex-direction: column;
  gap: 1rpx;
  padding: 1rpx;
  background: #EEEEEE;
  margin: 0;
  border-radius: 0;
}

.info-cell {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  background: #FFFFFF;
  gap: 20rpx;
}

.info-icon {
  width: 40rpx;
  height: 40rpx;
  opacity: 1;
}

.info-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 0;
  min-width: 100rpx;
}

.info-value {
  font-size: 28rpx;
  color: #1A1A1A;
  font-weight: 500;
  line-height: 1.4;
}

.info-value .highlight {
  color: #1A1A1A;
  font-weight: 600;
  font-size: 32rpx;
}

/* ========== 通用卡片 ========== */
.section-card {
  background: #FFFFFF;
  margin: 0;
  border-radius: 0;
  padding: 32rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.card-header-simple {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1A1A1A;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  display: block;
}

.desc-text.highlight-text {
  color: #FF9800;
  font-weight: 600;
}

/* ========== 照片区域 ========== */
.photos-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.photo-item {
  aspect-ratio: 1;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.photo-img {
  width: 100%;
  height: 100%;
}

.no-photos {
  text-align: center;
  padding: 60rpx 30rpx;
  color: #999;
  font-size: 26rpx;
}

/* ========== 参与者列表 ========== */
.participants-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.participant-item {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #F5F5F5;
  border-radius: 36rpx;
}

.participant-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.participant-name {
  font-size: 26rpx;
  color: #1A1A1A;
  font-weight: 500;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #CCCCCC;
  margin-left: 8rpx;
}

.status-dot.checked-in {
  background: #1A1A1A;
}

.view-all-btn {
  display: flex;
  align-items: center;
  color: #1A1A1A;
  font-size: 24rpx;
  font-weight: 500;
  text-decoration: underline;
}

.arrow-icon {
  width: 28rpx;
  height: 28rpx;
  margin-left: 4rpx;
}

.no-participants {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* ========== 上传按钮 ========== */
.upload-btn {
  display: flex;
  align-items: center;
  background: #1A1A1A;
  color: #FFFFFF;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.upload-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 6rpx;
}

/* ========== 底部操作区 ========== */
.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #F0F0F0;
}

.btn {
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: #1A1A1A;
  color: #FFFFFF;
}

.btn-primary:active {
  opacity: 0.9;
}

.btn-secondary {
  background: #F5F5F5;
  color: #1A1A1A;
}

.btn-secondary:active {
  background: #EEEEEE;
}

.btn-full {
  width: 100%;
}

.checked-in-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: #F5F5F5;
  border-radius: 44rpx;
  color: #1A1A1A;
  font-size: 30rpx;
  font-weight: 600;
}

.badge-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 12rpx;
}

/* ========== 签到码弹窗 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  border-radius: 20rpx;
  width: 80%;
  max-width: 600rpx;
  padding: 0;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #1A1A1A;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  padding: 40rpx 32rpx;
  text-align: center;
}

.qr-code-img {
  width: 400rpx;
  height: 400rpx;
  margin-bottom: 24rpx;
  border-radius: 12rpx;
}

.qr-hint {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 24rpx;
}

.qr-actions {
  margin-bottom: 20rpx;
}

.btn-save {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #1A1A1A;
  color: #fff;
  font-size: 24rpx;
  padding: 14rpx 36rpx;
  border-radius: 24rpx;
  border: none;
}

.btn-save::after {
  border: none;
}

.qr-stats {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #F0F0F0;
}

.qr-stats text {
  font-size: 26rpx;
  color: #666666;
  font-weight: 500;
}

/* 管理员操作区 */
.admin-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.checkin-count {
  font-size: 24rpx;
  color: #999999;
}

.btn-small {
  height: 60rpx;
  padding: 0 32rpx;
  font-size: 26rpx;
}
