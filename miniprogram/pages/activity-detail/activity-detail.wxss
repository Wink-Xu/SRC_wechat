/* pages/activity-detail/activity-detail.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

.loading-box {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

/* 活动头部 */
.activity-header {
  background: linear-gradient(135deg, #9C27B0, #7B1FA2);
  padding: 40rpx 30rpx;
  color: #fff;
}

.status-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.points-badge {
  margin-left: 16rpx;
  padding: 6rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  font-size: 24rpx;
}

.activity-title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.4;
}

/* 信息卡片 */
.info-card {
  background: #fff;
  margin: 20rpx 30rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
}

.info-row:not(:last-child) {
  border-bottom: 1rpx solid #f5f5f5;
}

.info-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
  margin-top: 4rpx;
}

.info-content {
  flex: 1;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 30rpx;
  color: #333;
}

.info-value .highlight {
  color: #9C27B0;
  font-weight: 600;
}

/* 描述卡片 */
.desc-card,
.participants-card {
  background: #fff;
  margin: 20rpx 30rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 参与者列表 */
.participants-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.participant-item {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
  background: #f9f9f9;
  border-radius: 32rpx;
}

.participant-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.participant-name {
  font-size: 26rpx;
  color: #333;
}

/* 报名名单头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.view-all-btn {
  display: flex;
  align-items: center;
  color: #9C27B0;
  font-size: 26rpx;
}

.arrow-icon {
  width: 28rpx;
  height: 28rpx;
  margin-left: 4rpx;
}

.no-participants {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

.empty-participants {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* 底部操作区 */
.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.admin-actions {
  display: flex;
  gap: 20rpx;
}

.admin-actions .btn {
  flex: 1;
}

.checked-in-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background: #E8F5E9;
  border-radius: 12rpx;
  color: #9C27B0;
}

.badge-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 12rpx;
}

.btn-error {
  background: #f44336;
  color: #fff;
}