/* pages/activity-detail/activity-detail.wxss */

page {
  background: #F8F9FA;
}

.container {
  min-height: 100vh;
  background: #F8F9FA;
  padding-bottom: 160rpx;
}

.loading-box {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

/* ========== 封面图头部 ========== */
.cover-header {
  position: relative;
  height: 440rpx;
  overflow: hidden;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.cover-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(156,39,176,0.85) 100%);
}

.cover-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 0 30rpx 30rpx;
}

.status-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  background: rgba(255,255,255,0.95);
  color: #9C27B0;
}

.status-tag.tag-primary {
  background: rgba(255,255,255,0.95);
  color: #9C27B0;
}

.status-tag.tag-success {
  background: rgba(255,255,255,0.95);
  color: #4CAF50;
}

.status-tag.tag-warning {
  background: rgba(255,255,255,0.95);
  color: #FF9800;
}

.status-tag.tag-error {
  background: rgba(255,255,255,0.95);
  color: #F44336;
}

.status-tag.tag-secondary {
  background: rgba(255,255,255,0.95);
  color: #9E9E9E;
}

.activity-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.4;
  margin-bottom: 20rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

.points-tag {
  display: inline-flex;
  align-items: baseline;
  background: rgba(255,255,255,0.2);
  backdrop-filter: blur(10rpx);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

.points-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFD700;
}

.points-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  margin-left: 4rpx;
}

/* ========== 信息网格 ========== */
.info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 30rpx;
  background: #fff;
  margin: 24rpx 30rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.info-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 20rpx;
}

.info-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 12rpx;
  opacity: 0.8;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.4;
}

.info-value .highlight {
  color: #9C27B0;
  font-weight: 700;
  font-size: 32rpx;
}

/* ========== 通用卡片 ========== */
.section-card {
  background: #fff;
  margin: 24rpx 30rpx;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.card-header-simple {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.desc-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  display: block;
}

.desc-text.highlight-text {
  color: #FF9800;
  font-weight: 600;
}

/* ========== 照片区域 ========== */
.photos-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.photo-item {
  aspect-ratio: 1;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.photo-img {
  width: 100%;
  height: 100%;
}

.no-photos {
  text-align: center;
  padding: 60rpx 30rpx;
  color: #999;
  font-size: 26rpx;
}

/* ========== 参与者列表 ========== */
.participants-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.participant-item {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #F8F9FA;
  border-radius: 32rpx;
}

.participant-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.participant-name {
  font-size: 26rpx;
  color: #333;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #E0E0E0;
  margin-left: 8rpx;
}

.status-dot.checked-in {
  background: #4CAF50;
}

.view-all-btn {
  display: flex;
  align-items: center;
  color: #9C27B0;
  font-size: 24rpx;
}

.arrow-icon {
  width: 28rpx;
  height: 28rpx;
  margin-left: 4rpx;
}

.no-participants {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* ========== 上传按钮 ========== */
.upload-btn {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #9C27B0, #7B1FA2);
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
}

.upload-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 6rpx;
}

/* ========== 底部操作区 ========== */
.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
}

.btn {
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #9C27B0, #7B1FA2);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(156,39,176,0.4);
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-secondary {
  background: #f5f5f5;
  color: #333;
}

.btn-secondary:active {
  background: #e8e8e8;
}

.btn-full {
  width: 100%;
}

.checked-in-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  border-radius: 48rpx;
  color: #4CAF50;
  font-size: 30rpx;
  font-weight: 600;
}

.badge-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 12rpx;
}

/* ========== 签到码弹窗 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  border-radius: 24rpx;
  width: 80%;
  max-width: 600rpx;
  padding: 0;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  padding: 40rpx 30rpx;
  text-align: center;
}

.qr-code-placeholder {
  margin-bottom: 24rpx;
}

.qr-hint {
  display: block;
  font-size: 26rpx;
  color: #666;
}

.qr-stats {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.qr-stats text {
  font-size: 28rpx;
  color: #9C27B0;
  font-weight: 600;
}

/* 管理员操作区 */
.admin-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.checkin-count {
  font-size: 24rpx;
  color: #666;
}

.btn-small {
  height: 64rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
}
