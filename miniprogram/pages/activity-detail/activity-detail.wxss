/* pages/activity-detail/activity-detail.wxss - On Running 极简风格 */

page {
  background: var(--background);
}

.container {
  min-height: 100vh;
  background: var(--background);
  padding-bottom: 180rpx;
}

.loading-box {
  text-align: center;
  padding: 120rpx;
  color: var(--text-secondary);
  font-size: 28rpx;
}

/* ========== 封面图头部 - 极简设计 ========== */
.cover-header {
  position: relative;
  height: 480rpx;
  overflow: hidden;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.cover-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.6) 100%);
}

.cover-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 0 40rpx 40rpx;
}

.status-tag {
  display: inline-block;
  padding: 10rpx 24rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  background: var(--background);
  color: var(--primary);
  letter-spacing: 0.5rpx;
}

.status-tag.tag-primary {
  background: var(--primary);
  color: var(--background);
}

.status-tag.tag-success {
  background: var(--background);
  color: var(--success);
  border: 1rpx solid var(--success);
}

.status-tag.tag-warning {
  background: var(--background);
  color: var(--warning);
  border: 1rpx solid var(--warning);
}

.status-tag.tag-error {
  background: var(--background);
  color: var(--error);
  border: 1rpx solid var(--error);
}

.status-tag.tag-secondary {
  background: var(--surface);
  color: var(--text-secondary);
}

.activity-title {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1.3;
  margin-bottom: 24rpx;
  letter-spacing: -1rpx;
  text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.4);
}

.points-tag {
  display: inline-flex;
  align-items: baseline;
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(10rpx);
  padding: 10rpx 24rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(255,255,255,0.3);
}

.points-value {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: -0.5rpx;
}

.points-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  margin-left: 6rpx;
  font-weight: 500;
}

/* ========== 信息网格 - 瑞士风格 ========== */
.info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rpx;
  padding: 1rpx;
  background: var(--divider);
  margin: 32rpx 40rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.info-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 36rpx 24rpx;
  background: var(--background);
}

.info-icon {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 16rpx;
  opacity: 1;
}

.info-label {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-bottom: 10rpx;
  font-weight: 400;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.info-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 600;
  line-height: 1.4;
  letter-spacing: -0.3rpx;
}

.info-value .highlight {
  color: var(--primary);
  font-weight: 800;
  font-size: 34rpx;
}

/* ========== 通用卡片 - 极简设计 ========== */
.section-card {
  background: var(--background);
  margin: 24rpx 40rpx;
  border-radius: 12rpx;
  padding: 40rpx;
  border: 1rpx solid var(--divider);
}

.card-header-simple {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.5rpx;
}

.desc-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.9;
  display: block;
}

.desc-text.highlight-text {
  color: var(--warning);
  font-weight: 600;
}

/* ========== 照片区域 ========== */
.photos-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rpx;
  background: var(--divider);
  border-radius: 12rpx;
  overflow: hidden;
}

.photo-item {
  aspect-ratio: 1;
  background: var(--surface);
}

.photo-img {
  width: 100%;
  height: 100%;
}

.no-photos {
  text-align: center;
  padding: 80rpx 30rpx;
  color: var(--text-hint);
  font-size: 26rpx;
}

/* ========== 参与者列表 ========== */
.participants-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.participant-item {
  display: flex;
  align-items: center;
  padding: 14rpx 24rpx;
  background: var(--surface);
  border-radius: 40rpx;
}

.participant-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 14rpx;
  background: var(--accent);
}

.participant-name {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--accent);
  margin-left: 10rpx;
}

.status-dot.checked-in {
  background: var(--success);
}

.view-all-btn {
  display: flex;
  align-items: center;
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 600;
}

.arrow-icon {
  width: 28rpx;
  height: 28rpx;
  margin-left: 6rpx;
}

.no-participants {
  text-align: center;
  padding: 60rpx;
  color: var(--text-hint);
  font-size: 26rpx;
}

/* ========== 上传按钮 ========== */
.upload-btn {
  display: flex;
  align-items: center;
  background: var(--primary);
  color: var(--background);
  padding: 14rpx 28rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.upload-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
}

/* ========== 底部操作区 ========== */
.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--background);
  padding: 28rpx 40rpx;
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--divider);
}

.btn {
  height: 100rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  letter-spacing: -0.5rpx;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: var(--primary);
  color: var(--background);
}

.btn-primary:active {
  opacity: 0.9;
}

.btn-secondary {
  background: var(--surface);
  color: var(--text-primary);
}

.btn-secondary:active {
  background: var(--accent);
}

.btn-full {
  width: 100%;
}

.checked-in-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  background: var(--surface);
  border-radius: 12rpx;
  color: var(--success);
  font-size: 30rpx;
  font-weight: 700;
}

.badge-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 14rpx;
}

.checkin-hint-box {
  text-align: center;
  padding: 20rpx;
}

.checkin-hint {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* ========== 签到码弹窗 - 极简设计 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: var(--background);
  border-radius: 16rpx;
  width: 82%;
  max-width: 640rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid var(--divider);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.5rpx;
}

.modal-close {
  font-size: 44rpx;
  color: var(--text-hint);
  line-height: 1;
  padding: 8rpx;
}

.modal-close:active {
  opacity: 0.5;
}

.modal-body {
  padding: 48rpx 40rpx;
  text-align: center;
}

.qr-code-img {
  width: 440rpx;
  height: 440rpx;
  margin-bottom: 32rpx;
  border-radius: 12rpx;
  border: 1rpx solid var(--divider);
}

.qr-hint {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 32rpx;
  font-weight: 500;
}

.qr-actions {
  margin-bottom: 24rpx;
}

.btn-save {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--primary);
  color: var(--background);
  font-size: 26rpx;
  font-weight: 600;
  padding: 16rpx 40rpx;
  border-radius: 8rpx;
  border: none;
  letter-spacing: 0.3rpx;
}

.btn-save::after {
  border: none;
}

.qr-stats {
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid var(--divider);
}

.qr-stats text {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

/* 管理员操作区 */
.admin-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.checkin-count {
  font-size: 24rpx;
  color: var(--text-hint);
  font-weight: 500;
}

.btn-small {
  height: 68rpx;
  padding: 0 36rpx;
  font-size: 28rpx;
}
