/* pages/activity-create/activity-create.wxss - 极简分组风格 */

.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 20rpx 24rpx 180rpx;
}

/* 分组标题 */
.form-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 26rpx;
  color: #999999;
  padding: 0 8rpx 16rpx;
  font-weight: 500;
}

.section-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
}

/* 表单项 */
.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-item.inline {
  display: flex;
  align-items: center;
}

.form-label {
  font-size: 26rpx;
  color: #1A1A1A;
  font-weight: 500;
  margin-bottom: 12rpx;
  display: block;
}

.form-item.inline .form-label {
  margin-bottom: 0;
  flex-shrink: 0;
  width: 140rpx;
}

.form-label.required::before {
  content: '*';
  color: #F44336;
  margin-right: 6rpx;
}

/* 输入框 - 底部边框风格 */
.form-input {
  height: 72rpx;
  line-height: 72rpx;
  border-bottom: 1rpx solid #E5E5E5;
  font-size: 28rpx;
  color: #1A1A1A;
  padding: 0 8rpx;
  background: transparent;
}

.form-input:focus {
  border-bottom-color: #1A1A1A;
}

.form-input.small {
  flex: 1;
  text-align: center;
  max-width: 120rpx;
}

.input-suffix {
  font-size: 26rpx;
  color: #666666;
  margin-left: 8rpx;
}

/* 文本域 */
.form-textarea {
  width: 100%;
  height: 160rpx;
  padding: 16rpx 8rpx;
  font-size: 28rpx;
  color: #1A1A1A;
  border-bottom: 1rpx solid #E5E5E5;
  background: transparent;
  box-sizing: border-box;
}

/* 地点行 */
.location-row {
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #E5E5E5;
}

.location-input {
  flex: 1;
  border-bottom: none;
}

.location-btn {
  padding: 12rpx 20rpx;
  background: #1A1A1A;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.location-btn text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* 类型选择 */
.type-grid {
  display: flex;
  gap: 16rpx;
}

.type-item {
  flex: 1;
  padding: 20rpx 0;
  text-align: center;
  border: 1rpx solid #E5E5E5;
  border-radius: 8rpx;
}

.type-item.active {
  background: #1A1A1A;
  border-color: #1A1A1A;
}

.type-item text {
  font-size: 26rpx;
  color: #333333;
}

.type-item.active text {
  color: #FFFFFF;
}

/* 时间选择行 */
.picker-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 72rpx;
  border-bottom: 1rpx solid #E5E5E5;
  padding: 0 8rpx;
  box-sizing: border-box;
}

.picker-row text {
  font-size: 28rpx;
  color: #1A1A1A;
  line-height: 1;
}

.picker-row .placeholder {
  color: #999999;
}

.picker-arrow {
  font-size: 32rpx;
  color: #CCCCCC;
  font-weight: 300;
  line-height: 1;
}

/* 确保 picker 组件不影响布局 */
picker {
  display: block;
  width: 100%;
}

/* 封面图 - 16:9 比例，与活动列表页统一 */
.cover-wrapper {
  margin-top: 12rpx;
}

.cover-upload {
  /* 16:9 比例：宽度 100%，高度 = 宽度 / 16 * 9 */
  height: 0;
  padding-bottom: 56.25%;
  border: 2rpx dashed #CCCCCC;
  border-radius: 12rpx;
  position: relative;
}

.upload-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -100%);
  font-size: 48rpx;
  color: #CCCCCC;
  line-height: 1;
}

.upload-hint {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, 16rpx);
  font-size: 24rpx;
  color: #999999;
}

.cover-preview {
  position: relative;
  /* 16:9 比例 */
  height: 0;
  padding-bottom: 56.25%;
  border-radius: 12rpx;
  overflow: hidden;
}

.cover-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.cover-delete {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #FFFFFF;
  line-height: 1;
}

.cover-reupload {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12rpx;
  background: rgba(0, 0, 0, 0.5);
  text-align: center;
  font-size: 22rpx;
  color: #FFFFFF;
}

/* 提交按钮 */
.submit-wrapper {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #F5F5F5;
}

.submit-btn {
  background: #1A1A1A;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 12rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.submit-btn::after {
  border: none;
}