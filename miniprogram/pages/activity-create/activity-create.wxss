/* pages/activity-create/activity-create.wxss - On Running 极简风格 */

.container {
  min-height: 100vh;
  background: var(--background);
  padding: 20rpx 30rpx 160rpx;
}

.form-card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  border: 1rpx solid #F0F0F0;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #1A1A1A;
  display: block;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-label.required::before {
  content: '*';
  color: #F44336;
  margin-right: 8rpx;
}

.form-input {
  height: 88rpx;
  padding: 0 24rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #1A1A1A;
  border: 1rpx solid transparent;
}

.form-input:focus {
  border-color: #1A1A1A;
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  padding: 20rpx 24rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #1A1A1A;
  box-sizing: border-box;
  border: 1rpx solid transparent;
}

.form-textarea:focus {
  border-color: #1A1A1A;
}

.form-picker {
  height: 88rpx;
  padding: 0 24rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid transparent;
}

.form-picker text {
  font-size: 30rpx;
  color: #1A1A1A;
}

.form-picker .placeholder {
  color: #999999;
}

/* 一行两列 */
.form-row {
  display: flex;
  gap: 20rpx;
}

.form-item-half {
  flex: 1;
}

/* 单选按钮组 */
.radio-group {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.radio-item {
  width: calc(50% - 10rpx);
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
  border: 1rpx solid transparent;
}

.radio-item.active {
  background: #FFFFFF;
  border-color: #1A1A1A;
}

.radio-inner {
  display: flex;
  align-items: center;
}

.radio-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #E0E0E0;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.radio-dot.active {
  background: #1A1A1A;
}

.radio-inner text {
  font-size: 28rpx;
  color: #1A1A1A;
}

.submit-btn {
  position: fixed;
  bottom: 40rpx;
  left: 30rpx;
  right: 30rpx;
  margin: 0;
  background: #1A1A1A;
  color: #FFFFFF;
  border: none;
  border-radius: 32rpx;
  font-weight: 500;
}