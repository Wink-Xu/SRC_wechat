/* pages/activity-create/activity-create.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx 30rpx 160rpx;
}

.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.form-label.required::before {
  content: '*';
  color: #f44336;
  margin-right: 8rpx;
}

.form-input {
  height: 88rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.form-picker {
  height: 88rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
}

.form-picker text {
  font-size: 30rpx;
}

.form-picker .placeholder {
  color: #999;
}

/* 一行两列 */
.form-row {
  display: flex;
  gap: 20rpx;
}

.form-item-half {
  flex: 1;
}

/* 单选按钮组 */
.radio-group {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.radio-item {
  width: calc(50% - 10rpx);
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.radio-item.active {
  background: rgba(156, 39, 176, 0.1);
  border: 2rpx solid #9C27B0;
}

.radio-inner {
  display: flex;
  align-items: center;
}

.radio-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #e0e0e0;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.radio-dot.active {
  background: #9C27B0;
}

.radio-inner text {
  font-size: 28rpx;
  color: #333;
}

.submit-btn {
  position: fixed;
  bottom: 40rpx;
  left: 30rpx;
  right: 30rpx;
  margin: 0;
}