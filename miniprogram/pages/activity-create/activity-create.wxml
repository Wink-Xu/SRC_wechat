<!--pages/activity-create/activity-create.wxml-->
<view class="container">
  <!-- 基本信息 -->
  <view class="form-section">
    <view class="section-title">基本信息</view>
    <view class="section-card">
      <!-- 封面图 -->
      <view class="form-item">
        <text class="form-label required">封面图</text>
        <view class="cover-wrapper">
          <view class="cover-upload" wx:if="{{!formData.cover_image}}" bindtap="chooseImage">
            <text class="upload-icon">+</text>
            <text class="upload-hint">上传封面</text>
          </view>
          <view class="cover-preview" wx:if="{{formData.cover_image}}" bindtap="chooseImage">
            <image class="cover-img" src="{{formData.cover_image}}" mode="aspectFill"></image>
            <view class="cover-delete" catchtap="removeImage">×</view>
            <view class="cover-reupload">点击更换</view>
          </view>
        </view>
      </view>

      <!-- 标题 -->
      <view class="form-item">
        <text class="form-label required">活动标题</text>
        <input
          class="form-input"
          type="text"
          placeholder="请输入活动标题"
          value="{{formData.title}}"
          bindinput="onTitleInput"
          maxlength="50"
        />
      </view>

      <!-- 描述 -->
      <view class="form-item">
        <text class="form-label required">活动描述</text>
        <textarea
          class="form-textarea"
          placeholder="请输入活动描述"
          value="{{formData.description}}"
          bindinput="onDescInput"
          maxlength="500"
        ></textarea>
      </view>

      <!-- 地点 -->
      <view class="form-item">
        <text class="form-label required">集合地点</text>
        <view class="location-row">
          <input
            class="form-input location-input"
            type="text"
            placeholder="请输入地点"
            value="{{formData.location}}"
            bindinput="onLocationInput"
            maxlength="100"
          />
          <view class="location-btn" bindtap="chooseLocation">
            <text>选点</text>
          </view>
        </view>
      </view>

      <!-- 跑步类型 -->
      <view class="form-item">
        <text class="form-label required">跑步类型</text>
        <view class="type-grid">
          <view
            class="type-item {{formData.run_type === item.value ? 'active' : ''}}"
            wx:for="{{runTypes}}"
            wx:key="value"
            bindtap="onRunTypeChange"
            data-value="{{item.value}}"
          >
            <text>{{item.label}}</text>
          </view>
        </view>
      </view>

      <!-- Dress Code -->
      <view class="form-item">
        <text class="form-label required">Dress Code</text>
        <input
          class="form-input"
          type="text"
          placeholder="例如：统一穿跑团队服"
          value="{{formData.dress_code}}"
          bindinput="onDressCodeInput"
          maxlength="50"
        />
      </view>
    </view>
  </view>

  <!-- 时间设置 -->
  <view class="form-section">
    <view class="section-title">时间设置</view>
    <view class="section-card">
      <view class="form-item">
        <text class="form-label required">活动时间</text>
        <datetime-picker
          title="选择活动时间"
          value="{{formData.start_datetime}}"
          bind:change="onStartDatetimeChange"
        >
          <view class="picker-row">
            <text class="{{formData.start_datetime_display ? '' : 'placeholder'}}">
              {{formData.start_datetime_display || '请选择日期和时间'}}
            </text>
            <text class="picker-arrow">›</text>
          </view>
        </datetime-picker>
      </view>

      <view class="form-item">
        <text class="form-label">报名截止</text>
        <datetime-picker
          title="选择报名截止时间"
          value="{{formData.registration_deadline}}"
          bind:change="onRegistrationDeadlineChange"
        >
          <view class="picker-row">
            <text class="{{formData.registration_deadline_display ? '' : 'placeholder'}}">
              {{formData.registration_deadline_display || '不设置截止时间'}}
            </text>
            <text class="picker-arrow">›</text>
          </view>
        </datetime-picker>
      </view>
    </view>
  </view>

  <!-- 名额与积分 -->
  <view class="form-section">
    <view class="section-title">名额与积分</view>
    <view class="section-card">
      <view class="form-item inline">
        <text class="form-label required">名额限制</text>
        <input
          class="form-input small"
          type="number"
          placeholder="20"
          value="{{formData.quota}}"
          bindinput="onQuotaInput"
        />
        <text class="input-suffix">人</text>
      </view>

      <view class="form-item inline">
        <text class="form-label required">参与积分</text>
        <input
          class="form-input small"
          type="number"
          placeholder="10"
          value="{{formData.points}}"
          bindinput="onPointsInput"
        />
        <text class="input-suffix">分</text>
      </view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-wrapper">
    <button class="submit-btn" bindtap="handleSubmit">
      {{isEdit ? '保存修改' : '创建活动'}}
    </button>
  </view>
</view>

<!-- 封面调整组件 -->
<cover-adjuster
  id="coverAdjuster"
  outputWidth="{{750}}"
  outputHeight="{{422}}"
  bind:confirm="onCoverConfirm"
  bind:cancel="onCoverCancel"
/>