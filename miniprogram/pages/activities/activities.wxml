<!--pages/activities/activities.wxml-->
<view class="container">
  <view wx:if="{{loading && ongoingActivities.length === 0 && pastActivities.length === 0}}" class="loading-box">
    <text>加载中...</text>
  </view>

  <view wx:elif="{{ongoingActivities.length === 0 && pastActivities.length === 0}}" class="empty-box">
    <image class="empty-icon" src="/images/empty.png" mode="aspectFit"></image>
    <text class="empty-text">暂无活动</text>
  </view>

  <!-- 正在报名的活动 -->
  <view wx:if="{{ongoingActivities.length > 0}}" class="section">
    <view class="section-header">
      <text class="section-title">正在报名</text>
      <text class="section-count">{{ongoingActivities.length}}个活动</text>
    </view>
    <view
      class="activity-card"
      wx:for="{{ongoingActivities}}"
      wx:key="_id"
      bindtap="goToDetail"
      data-id="{{item._id}}"
    >
      <view class="activity-header">
        <text class="activity-title">{{item.title}}</text>
        <text class="tag {{item.statusClass}}">{{item.statusText}}</text>
      </view>

      <view class="activity-info">
        <view class="info-item">
          <image class="info-icon" src="/images/time.png"></image>
          <text>{{item.formattedTime}}</text>
        </view>
        <view class="info-item">
          <image class="info-icon" src="/images/location.png"></image>
          <text>{{item.location}}</text>
        </view>
        <view class="info-item" wx:if="{{item.run_type}}">
          <image class="info-icon" src="/images/user.png"></image>
          <text>{{item.runTypeText}}</text>
        </view>
        <view class="info-item" wx:if="{{item.registration_deadline}}">
          <image class="info-icon" src="/images/time.png"></image>
          <text class="deadline-text">报名截止：{{item.registration_deadline}}</text>
        </view>
      </view>

      <view class="activity-footer">
        <view class="quota-info">
          <text class="registered-count">{{item.registered_count || 0}}</text>
          <text class="quota-text">/{{item.quota}}人</text>
        </view>
        <view class="points-info">
          <text class="points-value">+{{item.points}}</text>
          <text class="points-label">积分</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 往期活动 -->
  <view wx:if="{{pastActivities.length > 0}}" class="section">
    <view class="section-header">
      <text class="section-title">往期活动</text>
      <text class="section-count">{{pastActivities.length}}个活动</text>
    </view>
    <view
      class="past-card"
      wx:for="{{pastActivities}}"
      wx:key="_id"
      bindtap="goToDetail"
      data-id="{{item._id}}"
    >
      <view class="cover-image">
        <image class="cover-img" src="{{item.cover_image || '/images/default-product.png'}}" mode="aspectFill"></image>
        <view class="cover-overlay">
          <text class="cover-status tag {{item.statusClass}}">{{item.statusText}}</text>
        </view>
      </view>
      <view class="past-info">
        <text class="past-title">{{item.title}}</text>
        <text class="past-date">{{item.formattedTime}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{loadingMore}}" class="loading-more">
    <text>加载更多...</text>
  </view>

  <view wx:if="{{!hasMore && (ongoingActivities.length > 0 || pastActivities.length > 0)}}" class="no-more">
    <text>没有更多了</text>
  </view>
</view>
