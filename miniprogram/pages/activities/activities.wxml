<!--pages/activities/activities.wxml-->
<view class="container">
  <!-- 选项卡 -->
  <view class="tabs">
    <view
      class="tab-item {{currentTab === item.key ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="key"
      data-key="{{item.key}}"
      bindtap="onTabChange"
    >
      <text>{{item.title}}</text>
    </view>
  </view>

  <!-- 活动列表 -->
  <view class="activity-list">
    <view wx:if="{{loading && activities.length === 0}}" class="loading-box">
      <text>加载中...</text>
    </view>

    <view wx:elif="{{activities.length === 0}}" class="empty-box">
      <image class="empty-icon" src="/images/empty.png" mode="aspectFit"></image>
      <text class="empty-text">暂无活动</text>
    </view>

    <view
      class="activity-card"
      wx:for="{{activities}}"
      wx:key="_id"
      bindtap="goToDetail"
      data-id="{{item._id}}"
    >
      <view class="activity-header">
        <text class="activity-title">{{item.title}}</text>
        <text class="tag {{item.statusClass}}">{{item.statusText}}</text>
      </view>

      <view class="activity-info">
        <view class="info-item">
          <image class="info-icon" src="/images/time.png"></image>
          <text>{{item.formattedTime}}</text>
        </view>
        <view class="info-item">
          <image class="info-icon" src="/images/location.png"></image>
          <text>{{item.location}}</text>
        </view>
        <view class="info-item" wx:if="{{item.run_type}}">
          <image class="info-icon" src="/images/user.png"></image>
          <text>{{item.runTypeText}}</text>
        </view>
        <view class="info-item" wx:if="{{item.registration_deadline}}">
          <image class="info-icon" src="/images/time.png"></image>
          <text class="deadline-text">报名截止：{{item.registration_deadline}}</text>
        </view>
      </view>

      <view class="activity-footer">
        <view class="quota-info">
          <text class="registered-count">{{item.registered_count || 0}}</text>
          <text class="quota-text">/{{item.quota}}人</text>
        </view>
        <view class="points-info">
          <text class="points-value">+{{item.points}}</text>
          <text class="points-label">积分</text>
        </view>
      </view>
    </view>

    <view wx:if="{{loadingMore}}" class="loading-more">
      <text>加载更多...</text>
    </view>

    <view wx:if="{{!hasMore && activities.length > 0}}" class="no-more">
      <text>没有更多了</text>
    </view>
  </view>
</view>