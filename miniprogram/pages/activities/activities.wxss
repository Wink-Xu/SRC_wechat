/* pages/activities/activities.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 选项卡 */
.tabs {
  display: flex;
  background: #fff;
  padding: 20rpx 30rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #9C27B0;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #9C27B0;
  border-radius: 2rpx;
}

/* 活动列表 */
.activity-list {
  padding: 20rpx 30rpx;
}

.activity-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.activity-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  margin-right: 16rpx;
}

.activity-info {
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.info-item text {
  font-size: 26rpx;
  color: #666;
}

.info-item .deadline-text {
  color: #FF9800;
  font-size: 24rpx;
}

.activity-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f5f5f5;
}

.quota-info {
  font-size: 26rpx;
}

.registered-count {
  font-weight: 600;
  color: #9C27B0;
}

.quota-text {
  color: #999;
}

.points-info {
  display: flex;
  align-items: baseline;
}

.points-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF9800;
}

.points-label {
  font-size: 22rpx;
  color: #999;
  margin-left: 4rpx;
}

/* 加载状态 */
.loading-box,
.loading-more {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

.no-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 24rpx;
}

/* 空状态 */
.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}

/* 状态标签 */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-primary {
  background: rgba(156, 39, 176, 0.1);
  color: #9C27B0;
}

.tag-success {
  background: rgba(76, 175, 80, 0.1);
  color: #4CAF50;
}

.tag-warning {
  background: rgba(255, 152, 0, 0.1);
  color: #FF9800;
}

.tag-secondary {
  background: rgba(158, 158, 158, 0.1);
  color: #9E9E9E;
}

.tag-error {
  background: rgba(244, 67, 54, 0.1);
  color: #F44336;
}