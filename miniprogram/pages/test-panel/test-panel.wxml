<!--pages/test-panel/test-panel.wxml-->
<view class="container">
  <view class="header">
    <view class="title">切换测试角色</view>
    <view class="desc">每个角色有独立的 openid，报名状态独立</view>
  </view>

  <view class="current-user" wx:if="{{currentUser}}">
    <view class="current-label">当前角色</view>
    <view class="current-name">{{currentUser.nickname}}</view>
    <view class="current-role">{{currentUser.roleText}}</view>
  </view>

  <view class="role-list">
    <view class="role-item {{currentRole === 'leader' ? 'active' : ''}}" bindtap="switchRole" data-role="leader">
      <view class="role-icon">👑</view>
      <view class="role-info">
        <view class="role-name">团长</view>
        <view class="role-desc">最高权限，可管理一切</view>
      </view>
      <view class="role-check">{{currentRole === 'leader' ? '✓' : ''}}</view>
    </view>

    <view class="role-item {{currentRole === 'admin' ? 'active' : ''}}" bindtap="switchRole" data-role="admin">
      <view class="role-icon">🔧</view>
      <view class="role-info">
        <view class="role-name">管理员</view>
        <view class="role-desc">可管理活动、商品、成员</view>
      </view>
      <view class="role-check">{{currentRole === 'admin' ? '✓' : ''}}</view>
    </view>

    <view class="role-item {{currentRole === 'member' ? 'active' : ''}}" bindtap="switchRole" data-role="member">
      <view class="role-icon">👤</view>
      <view class="role-info">
        <view class="role-name">团员</view>
        <view class="role-desc">可报名活动、兑换商品</view>
      </view>
      <view class="role-check">{{currentRole === 'member' ? '✓' : ''}}</view>
    </view>

    <view class="role-item {{currentRole === 'pending' ? 'active' : ''}}" bindtap="switchRole" data-role="pending">
      <view class="role-icon">⏳</view>
      <view class="role-info">
        <view class="role-name">待审批</view>
        <view class="role-desc">等待管理员审批</view>
      </view>
      <view class="role-check">{{currentRole === 'pending' ? '✓' : ''}}</view>
    </view>

    <view class="role-item {{currentRole === 'guest' ? 'active' : ''}}" bindtap="switchRole" data-role="guest">
      <view class="role-icon">🚶</view>
      <view class="role-info">
        <view class="role-name">游客</view>
        <view class="role-desc">只能浏览，无法操作</view>
      </view>
      <view class="role-check">{{currentRole === 'guest' ? '✓' : ''}}</view>
    </view>
  </view>

  <view class="tips">
    <view class="tips-title">💡 测试说明</view>
    <view class="tips-content">
      每个角色有独立的 openid，报名、积分等数据完全独立。
      切换角色后请刷新页面查看最新状态。
    </view>
  </view>

  <view class="db-section">
    <view class="db-status">
      <text class="db-label">数据库测试用户：</text>
      <text class="db-value {{dbUsersReady ? 'ready' : 'not-ready'}}">{{dbUsersReady ? '✅ 已初始化' : '❌ 未初始化'}}</text>
    </view>
    <button class="btn-init" bindtap="createDbUsers" wx:if="{{!dbUsersReady}}">
      初始化测试用户
    </button>
    <text class="db-hint" wx:if="{{!dbUsersReady}}">⚠️ 需要先初始化测试用户才能正常使用云函数权限验证</text>
  </view>

  <view class="footer">
    <button class="btn-back" bindtap="goBack">返回</button>
  </view>
</view>