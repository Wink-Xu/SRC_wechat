/* pages/test-panel/test-panel.wxss */
.container {
  padding: 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 30rpx;
  padding: 20rpx 0;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.current-user {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.current-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.current-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.current-role {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  display: inline-block;
  background: rgba(255, 255, 255, 0.2);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.role-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.role-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  gap: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s;
  border: 2rpx solid transparent;
}

.role-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: #667eea;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
}

.role-item.active .role-name,
.role-item.active .role-desc {
  color: #fff;
}

.role-icon {
  font-size: 40rpx;
}

.role-info {
  flex: 1;
}

.role-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.role-desc {
  font-size: 24rpx;
  color: #999;
}

.role-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

.tips {
  margin-top: 30rpx;
  padding: 20rpx;
  background: #e3f2fd;
  border-radius: 12rpx;
}

.tips-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #1976d2;
  margin-bottom: 8rpx;
}

.tips-content {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.footer {
  margin-top: 40rpx;
  padding: 0 40rpx;
}

.btn-back {
  background: #fff;
  color: #666;
  border: 1px solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 24rpx 0;
}

.db-section {
  margin-top: 30rpx;
  padding: 20rpx;
  background: #fff3e0;
  border-radius: 12rpx;
}

.db-status {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.db-label {
  font-size: 26rpx;
  color: #666;
}

.db-value {
  font-size: 26rpx;
  font-weight: 600;
}

.db-value.ready {
  color: #4caf50;
}

.db-value.not-ready {
  color: #f44336;
}

.btn-init {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
  border: none;
}

.db-hint {
  display: block;
  font-size: 24rpx;
  color: #ff9800;
  margin-top: 12rpx;
}