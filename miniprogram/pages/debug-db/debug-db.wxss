/* pages/debug-db/debug-db.wxss */
.container {
  padding: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.info-card {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1px solid #e0e0e0;
}

.info-row:last-child {
  border-bottom: none;
}

.label {
  color: #666;
}

.value {
  color: #333;
  font-weight: 500;
}

.value.small {
  font-size: 22rpx;
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.bool-true {
  color: #07c160;
}

.bool-false {
  color: #ee0a24;
}

.list-card {
  background: #fff;
  border: 1px solid #e0e0e0;
  border-radius: 16rpx;
  overflow: hidden;
}

.list-item {
  padding: 24rpx;
  border-bottom: 1px solid #e0e0e0;
}

.list-item:last-child {
  border-bottom: none;
}

.item-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.item-role,
.item-status {
  display: inline-block;
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
  background: #f5f5f5;
}

.empty-tip {
  text-align: center;
  color: #999;
  padding: 60rpx 20rpx;
}

.refresh-btn {
  margin-top: 40rpx;
  background: #1A1A1A;
  color: #fff;
  border-radius: 16rpx;
}

/* 诊断卡片样式 */
.diagnosis-card {
  background: #fff;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 24rpx;
}

.diagnosis-status {
  font-size: 32rpx;
  font-weight: bold;
  padding: 16rpx;
  border-radius: 8rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.diagnosis-status.has-issues {
  background: #ffe4e4;
  color: #ee0a24;
}

.diagnosis-status.ok {
  background: #e8f5e9;
  color: #07c160;
}

.diagnosis-list {
  margin-bottom: 20rpx;
}

.diagnosis-item {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
  border-bottom: 1px solid #f0f0f0;
}

.diagnosis-item:last-child {
  border-bottom: none;
}

.issue-icon {
  margin-right: 12rpx;
}

.issue-text {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.suggestion-list {
  background: #f9f9f9;
  border-radius: 8rpx;
  padding: 16rpx;
}

.suggestion-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #666;
  margin-bottom: 12rpx;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  padding: 8rpx 0;
}

.suggestion-icon {
  margin-right: 12rpx;
}

.suggestion-text {
  flex: 1;
  font-size: 24rpx;
  color: #666;
}

/* 修复按钮 */
.fix-btn {
  margin-top: 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
}

/* Issues 列表 */
.issues-list {
  margin-top: 8rpx;
}

.issue-item {
  display: flex;
  align-items: center;
  padding: 4rpx 0;
}

.issue-dot {
  margin-right: 8rpx;
  font-size: 24rpx;
}

.issue-text {
  font-size: 22rpx;
  color: #ee0a24;
}
