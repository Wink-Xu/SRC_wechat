/* pages/init/init.wxss */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
}

.icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.message {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 40rpx;
  text-align: center;
}

.results {
  width: 100%;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
}

.result-item {
  font-size: 28rpx;
  padding: 12rpx 0;
  border-bottom: 1px solid #e0e0e0;
}

.result-item:last-child {
  border-bottom: none;
}

.hint {
  font-size: 28rpx;
  color: #888;
  margin-top: 20rpx;
}
