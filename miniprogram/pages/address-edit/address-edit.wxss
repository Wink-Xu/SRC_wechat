/* pages/address-edit/address-edit.wxss - On Running 极简风格 */

.container {
  min-height: 100vh;
  background: #FFFFFF;
  padding: 20rpx 30rpx;
}

.form-card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
  border: 1rpx solid #F0F0F0;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #000000;
  display: block;
  margin-bottom: 12rpx;
  font-weight: 600;
}

.form-input {
  height: 80rpx;
  padding: 0 20rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #000000;
  border: 1rpx solid transparent;
}

.form-input:focus {
  border-color: #000000;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  padding: 20rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #000000;
  box-sizing: border-box;
  border: 1rpx solid transparent;
}

.form-textarea:focus {
  border-color: #000000;
}

.form-picker {
  height: 80rpx;
  padding: 0 20rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid transparent;
}

.form-picker text {
  font-size: 28rpx;
  color: #000000;
}

.form-picker .placeholder {
  color: #999999;
}

.save-btn {
  margin-bottom: 20rpx;
  background: #000000;
  color: #FFFFFF;
  border: none;
  border-radius: 32rpx;
  font-weight: 600;
}

.btn-error {
  background: #FFFFFF;
  color: #F44336;
  border: 1rpx solid #F44336;
  border-radius: 32rpx;
  font-weight: 600;
}