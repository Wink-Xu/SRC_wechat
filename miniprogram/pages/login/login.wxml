<!--pages/login/login.wxml-->
<view class="container">
  <!-- 背景图片 -->
  <image class="bg-image" src="/images/登陆页.png" mode="aspectFit"></image>

  <!-- 登录按钮 -->
  <view class="btn-section">
    <button class="login-btn" bindtap="handleLogin" loading="{{loading}}">
      微信登录
    </button>
  </view>
</view>