/* pages/login/login.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #9C27B0 0%, #7B1FA2 100%);
  padding: 0 40rpx;
  display: flex;
  flex-direction: column;
}

/* 登录步骤 */
.login-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding-top: 160rpx;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.app-slogan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.welcome-text {
  text-align: center;
  margin-bottom: 60rpx;
}

.welcome-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 16rpx;
}

.welcome-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  padding: 0 40rpx;
}

.login-btn {
  margin-top: auto;
  margin-bottom: 40rpx;
  background: #fff;
  color: #9C27B0;
  border: none;
}

.guest-entry {
  text-align: center;
  padding: 30rpx 0;
}

.guest-entry text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 微信头像昵称表单 */
.wx-profile-form {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
}

.wx-profile-form .form-item {
  margin-bottom: 32rpx;
}

.wx-profile-form .form-item:last-child {
  margin-bottom: 0;
}

.wx-profile-form .form-label {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.avatar-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: 2rpx dashed #ddd;
}

.avatar-btn text {
  font-size: 24rpx;
  color: #999;
}

.avatar-preview {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.wx-profile-form .form-input {
  height: 88rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 30rpx;
}

/* 申请步骤 */
.apply-section {
  flex: 1;
  padding-top: 80rpx;
}

.apply-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.apply-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 16rpx;
}

.apply-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.form-input {
  height: 88rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.submit-btn {
  background: #fff;
  color: #9C27B0;
}

.privacy-tips {
  text-align: center;
  padding: 30rpx 0;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.privacy-link {
  color: #fff;
}