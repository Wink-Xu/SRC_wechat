/* pages/login/login.wxss - On Running 极简风格 */

.container {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding-bottom: 60rpx;
  background: #FFFFFF;
}

/* 背景图片 - 自适应 */
.bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

/* 按钮区域 */
.btn-section {
  position: relative;
  z-index: 1;
  width: 100%;
  padding: 0 40rpx;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 96rpx;
  background: #000000;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  transform: scale(0.98);
}