/* pages/points-rank/points-rank.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.loading-box {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

/* 前三名 */
.top-three {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #9C27B0, #7B1FA2);
}

.top-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  position: relative;
}

.top-item.first {
  order: 2;
}

.top-item.second {
  order: 1;
}

.top-item.third {
  order: 3;
}

.top-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  margin-bottom: 12rpx;
}

.top-item.first .top-avatar {
  width: 120rpx;
  height: 120rpx;
}

.top-name {
  font-size: 28rpx;
  color: #fff;
  margin-bottom: 4rpx;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.top-points {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.top-badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 40rpx;
  height: 40rpx;
  background: #FFD700;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #333;
}

.top-item.first .top-badge {
  background: #FFD700;
}

.top-item.second .top-badge {
  background: #C0C0C0;
}

.top-item.third .top-badge {
  background: #CD7F32;
}

/* 排行列表 */
.rank-list {
  background: #fff;
  margin: 20rpx 30rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-num {
  width: 60rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #666;
}

.rank-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.rank-name {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.rank-points {
  font-size: 28rpx;
  color: #FF9800;
  font-weight: 600;
}

.empty-box {
  text-align: center;
  padding: 100rpx;
}

.empty-text {
  color: #999;
}