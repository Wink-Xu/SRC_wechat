/* pages/points-rank/points-rank.wxss - On Running 极简风格 */

.container {
  min-height: 100vh;
  background: var(--background);
}

.loading-box {
  text-align: center;
  padding: 100rpx;
  color: #999999;
}

/* 前三名 - 极简风格 */
.top-three {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  padding: 40rpx 30rpx;
  background: #1A1A1A;
}

.top-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  position: relative;
}

.top-item.first {
  order: 2;
}

.top-item.second {
  order: 1;
}

.top-item.third {
  order: 3;
}

.top-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid #FFFFFF;
  margin-bottom: 12rpx;
}

.top-item.first .top-avatar {
  width: 120rpx;
  height: 120rpx;
}

.top-name {
  font-size: 28rpx;
  color: #FFFFFF;
  margin-bottom: 4rpx;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
}

.top-points {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.top-badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 40rpx;
  height: 40rpx;
  background: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #000000;
}

.top-item.first .top-badge {
  background: #FFD700;
}

.top-item.second .top-badge {
  background: #C0C0C0;
}

.top-item.third .top-badge {
  background: #CD7F32;
}

/* 排行列表 */
.rank-list {
  background: #FFFFFF;
  margin: 20rpx 30rpx;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #F0F0F0;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-num {
  width: 60rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #666666;
}

.rank-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.rank-name {
  flex: 1;
  font-size: 30rpx;
  color: #1A1A1A;
  font-weight: 500;
}

.rank-points {
  font-size: 28rpx;
  color: #1A1A1A;
  font-weight: 600;
}

.empty-box {
  text-align: center;
  padding: 100rpx;
}

.empty-text {
  color: #999999;
}
