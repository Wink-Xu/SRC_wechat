/* pages/order-detail/order-detail.wxss - On Running 极简风格 */

.container {
  min-height: 100vh;
  background: #FFFFFF;
  padding-bottom: 160rpx;
}

.loading-box {
  text-align: center;
  padding: 100rpx;
  color: #999999;
}

/* 状态卡片 */
.status-card {
  padding: 40rpx 30rpx;
  color: #FFFFFF;
}

.status-pending {
  background: #CC7722;
}

.status-paid,
.status-shipped {
  background: #000000;
}

.status-completed {
  background: #2E7D32;
}

.status-cancelled {
  background: #9E9E9E;
}

.status-text {
  font-size: 36rpx;
  font-weight: 700;
}

/* 收货地址 */
.address-card {
  display: flex;
  background: #FFFFFF;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #F0F0F0;
  border-radius: 12rpx;
}

.address-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
  opacity: 0.7;
}

.address-icon image {
  width: 100%;
  height: 100%;
}

.address-info {
  flex: 1;
}

.address-name {
  font-size: 30rpx;
  color: #000000;
  display: block;
  margin-bottom: 8rpx;
  font-weight: 600;
}

.address-detail {
  font-size: 26rpx;
  color: #666666;
}

/* 商品卡片 */
.product-card {
  background: #FFFFFF;
  margin-bottom: 20rpx;
  border: 1rpx solid #F0F0F0;
  border-radius: 12rpx;
}

.product-header {
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.header-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #000000;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.product-content {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
}

.product-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.product-info {
  flex: 1;
}

.product-name {
  font-size: 28rpx;
  color: #000000;
  display: block;
  margin-bottom: 8rpx;
  font-weight: 600;
}

.product-meta {
  font-size: 24rpx;
  color: #999999;
}

.product-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #000000;
}

/* 信息卡片 */
.info-card {
  background: #FFFFFF;
  padding: 24rpx 30rpx;
  border: 1rpx solid #F0F0F0;
  border-radius: 12rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #999999;
}

.info-value {
  font-size: 28rpx;
  color: #000000;
  display: flex;
  align-items: center;
  font-weight: 600;
}

.copy-btn {
  margin-left: 16rpx;
  padding: 4rpx 16rpx;
  background: #F5F5F5;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #666666;
  border: 1rpx solid #E0E0E0;
}

/* 底部操作 */
.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.footer-actions .btn {
  width: 200rpx;
  background: #000000;
  color: #FFFFFF;
  border: none;
  border-radius: 32rpx;
  font-weight: 600;
}