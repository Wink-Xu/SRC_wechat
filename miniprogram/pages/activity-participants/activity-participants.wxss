/* pages/activity-participants/activity-participants.wxss - On Running 极简风格 */

.container {
  min-height: 100vh;
  background: #FFFFFF;
  padding-bottom: 30rpx;
}

.loading-box {
  text-align: center;
  padding: 100rpx;
  color: #999999;
}

/* 活动头部 */
.activity-header {
  background: #1A1A1A;
  padding: 40rpx 30rpx;
  color: #FFFFFF;
}

.activity-title {
  font-size: 36rpx;
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
}

.activity-stats {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 报名名单列表 */
.participants-list {
  padding: 20rpx 30rpx;
}

.participant-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #F0F0F0;
}

.participant-index {
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A1A;
  width: 48rpx;
  text-align: center;
}

.participant-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  margin: 0 24rpx 0 16rpx;
}

.participant-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: #1A1A1A;
}

.participant-status {
  display: flex;
  align-items: center;
}

.status-badge {
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  background: #F5F5F5;
  color: #666666;
}

.status-badge.checked-in {
  background: #F5F5F5;
  color: #1A1A1A;
}

.status-badge.registered {
  background: #F5F5F5;
  color: #666666;
}

/* 空状态 */
.empty-box {
  text-align: center;
  padding: 100rpx 30rpx;
  color: #999999;
  font-size: 28rpx;
}
