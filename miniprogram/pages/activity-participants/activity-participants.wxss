/* pages/activity-participants/activity-participants.wxss */

.container {
  min-height: 100vh;
  background: #F8F9FA;
  padding-bottom: 30rpx;
}

.loading-box {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

/* 活动头部 */
.activity-header {
  background: linear-gradient(135deg, #9C27B0, #7B1FA2);
  padding: 40rpx 30rpx;
  color: #fff;
}

.activity-title {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 12rpx;
}

.activity-stats {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 报名名单列表 */
.participants-list {
  padding: 20rpx 30rpx;
}

.participant-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.participant-index {
  font-size: 28rpx;
  font-weight: 700;
  color: #9C27B0;
  width: 48rpx;
  text-align: center;
}

.participant-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  margin: 0 24rpx 0 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.participant-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.participant-status {
  display: flex;
  align-items: center;
}

.status-badge {
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.status-badge.checked-in {
  background: linear-gradient(135deg, #C8E6C9, #A5D6A7);
  color: #2E7D32;
}

.status-badge.registered {
  background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
  color: #1565C0;
}

/* 空状态 */
.empty-box {
  text-align: center;
  padding: 100rpx 30rpx;
  color: #999;
  font-size: 28rpx;
}
