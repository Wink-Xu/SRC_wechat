/* pages/admin-activities/admin-activities.wxss - On Running 极简风格 */

.container {
  min-height: 100vh;
  background: var(--background);
  padding-bottom: 120rpx;
}

.activity-list {
  padding: 20rpx 30rpx;
}

.activity-card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #F0F0F0;
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.activity-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1A1A1A;
  flex: 1;
  margin-right: 16rpx;
}

.status-tag {
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
  background: #F5F5F5;
  color: #666666;
}

.status-draft {
  background: #F5F5F5;
  color: #CC7722;
}

.status-published {
  background: #F5F5F5;
  color: #2E7D32;
}

.status-ongoing {
  background: #F5F5F5;
  color: #1A1A1A;
}

.status-ended {
  background: #F5F5F5;
  color: #999999;
}

.status-cancelled {
  background: #F5F5F5;
  color: #F44336;
}

.activity-info {
  margin-bottom: 16rpx;
}

.info-text {
  font-size: 26rpx;
  color: #666666;
  display: block;
  margin-bottom: 8rpx;
}

.activity-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F5F5F5;
}

.btn-warning {
  background: #FFFFFF;
  color: #CC7722;
  border: 1rpx solid #CC7722;
  border-radius: 32rpx;
  font-weight: 600;
}

.btn-error {
  background: #FFFFFF;
  color: #F44336;
  border: 1rpx solid #F44336;
  border-radius: 32rpx;
  font-weight: 600;
}

.btn-danger {
  background: #FFFFFF;
  color: #F44336;
  border: 1rpx solid #F44336;
  border-radius: 32rpx;
  font-weight: 600;
}

/* 加载状态 */
.loading-box,
.loading-more {
  text-align: center;
  padding: 40rpx;
  color: #999999;
}

.no-more {
  text-align: center;
  padding: 30rpx;
  color: #999999;
  font-size: 24rpx;
}

.empty-box {
  text-align: center;
  padding: 60rpx;
}

.empty-text {
  color: #999999;
}

/* 悬浮按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background: #1A1A1A;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fab-icon {
  font-size: 48rpx;
  color: #FFFFFF;
}