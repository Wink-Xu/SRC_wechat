/* pages/admin-activities/admin-activities.wxss - On Running 极简风格 */

.container {
  min-height: 100vh;
  background: var(--background);
  padding-bottom: 120rpx;
}

.activity-list {
  padding: 20rpx 30rpx;
}

.activity-card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #F0F0F0;
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.activity-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1A1A1A;
  flex: 1;
  margin-right: 16rpx;
}

.status-tag {
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
  background: #F5F5F5;
  color: #666666;
}

.status-draft {
  background: #F5F5F5;
  color: #CC7722;
}

.status-published {
  background: #F5F5F5;
  color: #2E7D32;
}

.status-ongoing {
  background: #F5F5F5;
  color: #1A1A1A;
}

.status-ended {
  background: #F5F5F5;
  color: #999999;
}

.status-cancelled {
  background: #F5F5F5;
  color: #F44336;
}

.activity-info {
  margin-bottom: 16rpx;
}

.info-text {
  font-size: 26rpx;
  color: #666666;
  display: block;
  margin-bottom: 8rpx;
}

.activity-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F5F5F5;
}

.btn-warning {
  background: #FFFFFF;
  color: #CC7722;
  border: 1rpx solid #CC7722;
  border-radius: 32rpx;
  font-weight: 600;
}

.btn-error {
  background: #FFFFFF;
  color: #F44336;
  border: 1rpx solid #F44336;
  border-radius: 32rpx;
  font-weight: 600;
}

.btn-danger {
  background: #FFFFFF;
  color: #F44336;
  border: 1rpx solid #F44336;
  border-radius: 32rpx;
  font-weight: 600;
}

/* 加载状态 */
.loading-box,
.loading-more {
  text-align: center;
  padding: 40rpx;
  color: #999999;
}

.no-more {
  text-align: center;
  padding: 30rpx;
  color: #999999;
  font-size: 24rpx;
}

.empty-box {
  text-align: center;
  padding: 60rpx;
}

.empty-text {
  color: #999999;
}

/* 悬浮按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background: #1A1A1A;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fab-icon {
  font-size: 48rpx;
  color: #FFFFFF;
}

/* 按钮样式 */
.btn {
  height: 60rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
  padding: 0 24rpx;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: #1A1A1A;
  color: #FFFFFF;
}

.btn-secondary {
  background: #F5F5F5;
  color: #1A1A1A;
}

.btn-info {
  background: #FFFFFF;
  color: #1A1A1A;
  border: 1rpx solid #1A1A1A;
}

.btn-small {
  height: 56rpx;
  font-size: 24rpx;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  border-radius: 20rpx;
  width: 80%;
  max-width: 600rpx;
  padding: 0;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #1A1A1A;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  padding: 40rpx 32rpx;
  text-align: center;
}

.qr-code-img {
  width: 400rpx;
  height: 400rpx;
  margin-bottom: 24rpx;
  border-radius: 12rpx;
}

.qr-hint {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 24rpx;
}

.qr-actions {
  margin-bottom: 20rpx;
}

.btn-save {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #1A1A1A;
  color: #fff;
  font-size: 24rpx;
  padding: 14rpx 36rpx;
  border-radius: 24rpx;
  border: none;
}

.btn-save::after {
  border: none;
}

.qr-stats {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #F0F0F0;
}

.qr-stats text {
  font-size: 26rpx;
  color: #666666;
  font-weight: 500;
}