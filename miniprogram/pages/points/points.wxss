/* pages/points/points.wxss - On Running 极简风格 */

.container {
  min-height: 100vh;
  background: #FFFFFF;
}

/* 积分卡片 - 极简黑色风格 */
.points-card {
  background: #000000;
  margin: 30rpx;
  border-radius: 12rpx;
  padding: 40rpx;
  color: #FFFFFF;
}

.points-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.points-label {
  font-size: 28rpx;
  opacity: 0.8;
  color: #FFFFFF;
}

.rank-link {
  font-size: 26rpx;
  opacity: 0.6;
  color: #FFFFFF;
}

.points-value {
  font-size: 72rpx;
  font-weight: 800;
  display: block;
  margin-bottom: 16rpx;
  color: #FFFFFF;
  letter-spacing: -1rpx;
}

.points-tip {
  font-size: 24rpx;
  opacity: 0.6;
  color: #FFFFFF;
}

/* 积分记录 */
.logs-section {
  padding: 0 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #000000;
  display: block;
  margin-bottom: 20rpx;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.logs-list {
  background: #FFFFFF;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #F0F0F0;
}

.log-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.log-item:last-child {
  border-bottom: none;
}

.log-info {
  display: flex;
  flex-direction: column;
}

.log-type {
  font-size: 30rpx;
  color: #000000;
  margin-bottom: 8rpx;
  font-weight: 600;
}

.log-time {
  font-size: 24rpx;
  color: #999999;
}

.log-points {
  font-size: 36rpx;
  font-weight: 700;
  color: #000000;
}

.log-points.positive {
  color: #2E7D32;
}

.log-points.negative {
  color: #F44336;
}

/* 加载状态 */
.loading-box,
.loading-more {
  text-align: center;
  padding: 40rpx;
  color: #999999;
}

.no-more {
  text-align: center;
  padding: 30rpx;
  color: #999999;
  font-size: 24rpx;
}

.empty-box {
  text-align: center;
  padding: 60rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  border: 1rpx solid #F0F0F0;
}

.empty-text {
  color: #999999;
}
