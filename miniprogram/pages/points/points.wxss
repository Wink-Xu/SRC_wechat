/* pages/points/points.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 积分卡片 */
.points-card {
  background: linear-gradient(135deg, #FF9800, #F57C00);
  margin: 30rpx;
  border-radius: 24rpx;
  padding: 40rpx;
  color: #fff;
}

.points-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.points-label {
  font-size: 28rpx;
  opacity: 0.9;
}

.rank-link {
  font-size: 26rpx;
  opacity: 0.8;
}

.points-value {
  font-size: 72rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 16rpx;
}

.points-tip {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 积分记录 */
.logs-section {
  padding: 0 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.logs-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.log-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.log-item:last-child {
  border-bottom: none;
}

.log-info {
  display: flex;
  flex-direction: column;
}

.log-type {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.log-time {
  font-size: 24rpx;
  color: #999;
}

.log-points {
  font-size: 36rpx;
  font-weight: 600;
}

.log-points.positive {
  color: #9C27B0;
}

.log-points.negative {
  color: #f44336;
}

/* 加载状态 */
.loading-box,
.loading-more {
  text-align: center;
  padding: 40rpx;
  color: #999;
}

.no-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 24rpx;
}

.empty-box {
  text-align: center;
  padding: 60rpx;
  background: #fff;
  border-radius: 16rpx;
}

.empty-text {
  color: #999;
}