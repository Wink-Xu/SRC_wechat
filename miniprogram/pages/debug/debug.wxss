/* pages/debug/debug.wxss */
.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.debug-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.debug-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.debug-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.role-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.role-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.role-item:last-child {
  border-bottom: none;
}

.role-item.active {
  background: rgba(156, 39, 176, 0.05);
}

.role-info {
  flex: 1;
}

.role-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.role-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.role-action {
  margin-left: 20rpx;
}

.switch-btn {
  padding: 12rpx 30rpx;
  background: #9C27B0;
  color: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.role-item.active .switch-btn {
  background: #9E9E9E;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.user-info text {
  font-size: 26rpx;
  color: #666;
}

.clear-btn {
  background: #f44336;
  color: #fff;
  border: none;
  font-size: 28rpx;
  padding: 24rpx;
  border-radius: 12rpx;
}
