/* pages/debug/debug.wxss - On Running 极简风格 */
.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #FFFFFF;
}

.debug-section {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #F0F0F0;
}

.debug-title {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 10rpx;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.debug-desc {
  display: block;
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 20rpx;
}

.role-list {
  background: #FFFFFF;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  border: 1rpx solid #F0F0F0;
}

.role-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.role-item:last-child {
  border-bottom: none;
}

.role-item.active {
  background: #F5F5F5;
}

.role-info {
  flex: 1;
}

.role-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}

.role-desc {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

.role-action {
  margin-left: 20rpx;
}

.switch-btn {
  padding: 12rpx 30rpx;
  background: #1A1A1A;
  color: #FFFFFF;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 500;
  border: none;
}

.role-item.active .switch-btn {
  background: #999999;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.user-info text {
  font-size: 26rpx;
  color: #666666;
}

.clear-btn {
  background: #FFFFFF;
  color: #F44336;
  border: 1rpx solid #F44336;
  font-size: 28rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  font-weight: 500;
}
