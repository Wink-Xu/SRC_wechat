<!--pages/admin-orders/admin-orders.wxml-->
<view class="container">
  <!-- 状态选项卡 -->
  <view class="status-tabs">
    <view
      class="tab-item {{currentStatus === item.key ? 'active' : ''}}"
      wx:for="{{statusTabs}}"
      wx:key="key"
      data-key="{{item.key}}"
      bindtap="onTabChange"
    >
      <text>{{item.title}}</text>
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <view wx:if="{{loading && orders.length === 0}}" class="loading-box">
      <text>加载中...</text>
    </view>

    <view wx:elif="{{orders.length === 0}}" class="empty-box">
      <text class="empty-text">暂无订单</text>
    </view>

    <view class="order-card" wx:for="{{orders}}" wx:key="_id">
      <view class="order-header">
        <text class="order-no">{{item.order_no}}</text>
        <text class="order-time">{{item.formattedTime}}</text>
      </view>

      <view class="order-user">
        <text class="user-name">{{item.address.name}}</text>
        <text class="user-phone">{{item.address.phone}}</text>
      </view>

      <view class="order-product">
        <text class="product-name">{{item.product_name}}</text>
        <text class="product-quantity">x{{item.quantity}}</text>
        <text class="product-price" wx:if="{{item.pay_method === 'points'}}">{{item.total_points}}积分</text>
        <text class="product-price" wx:else>¥{{item.cashPriceYuan}}</text>
      </view>

      <view class="order-address">
        <text>{{item.address.province}}{{item.address.city}}{{item.address.district}}{{item.address.detail}}</text>
      </view>

      <view class="order-footer">
        <text class="status-tag status-{{item.status}}">{{item.statusText}}</text>
        <button
          wx:if="{{item.status === 'paid'}}"
          class="btn btn-primary btn-small"
          data-id="{{item._id}}"
          bindtap="handleShip"
        >发货</button>
      </view>
    </view>

    <view wx:if="{{loadingMore}}" class="loading-more">
      <text>加载更多...</text>
    </view>

    <view wx:if="{{!hasMore && orders.length > 0}}" class="no-more">
      <text>没有更多了</text>
    </view>
  </view>
</view>