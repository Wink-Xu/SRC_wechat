/* pages/admin/admin.wxss - On Running 极简风格 */

.container {
  min-height: 100vh;
  background: var(--background);
}

.header {
  background: #FFFFFF;
  padding: 40rpx 30rpx;
  color: #1A1A1A;
  border-bottom: 1rpx solid #F0F0F0;
}

.header-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #1A1A1A;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

/* 数据统计 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 20rpx 30rpx;
}

.stat-card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 30rpx;
  text-align: center;
  border: 1rpx solid #F0F0F0;
}

.stat-card.highlight {
  background: #F5F5F5;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 600;
  color: #1A1A1A;
  display: block;
}

.stat-card.highlight .stat-value {
  color: #1A1A1A;
}

.stat-label {
  font-size: 26rpx;
  color: #999999;
  margin-top: 8rpx;
  display: block;
}

/* 菜单 */
.menu-section {
  padding: 0 30rpx;
}

.menu-group {
  background: #FFFFFF;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #F0F0F0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 20rpx;
  opacity: 0.7;
}

.menu-title {
  font-size: 30rpx;
  color: #1A1A1A;
  margin-right: 16rpx;
  font-weight: 500;
}

.menu-desc {
  flex: 1;
  font-size: 24rpx;
  color: #999999;
}

.menu-arrow {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.5;
}