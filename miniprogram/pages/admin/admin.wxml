<!--pages/admin/admin.wxml-->
<view class="container">
  <view class="header">
    <text class="header-title">管理后台</text>
  </view>

  <!-- 数据统计 -->
  <view class="stats-grid">
    <view class="stat-card" bindtap="goToPage" data-path="/pages/admin-members/admin-members">
      <text class="stat-value">{{statistics.memberCount}}</text>
      <text class="stat-label">团员总数</text>
    </view>
    <view class="stat-card highlight" bindtap="goToPage" data-path="/pages/admin-members/admin-members?status=pending">
      <text class="stat-value">{{statistics.pendingCount}}</text>
      <text class="stat-label">待审批</text>
    </view>
    <view class="stat-card" bindtap="goToPage" data-path="/pages/admin-activities/admin-activities">
      <text class="stat-value">{{statistics.activityCount}}</text>
      <text class="stat-label">活动总数</text>
    </view>
    <view class="stat-card" bindtap="goToPage" data-path="/pages/admin-orders/admin-orders">
      <text class="stat-value">{{statistics.orderCount}}</text>
      <text class="stat-label">订单总数</text>
    </view>
  </view>

  <!-- 管理入口 -->
  <view class="menu-section">
    <view class="menu-group">
      <view class="menu-item" bindtap="goToPage" data-path="/pages/admin-members/admin-members">
        <image class="menu-icon" src="/images/user.png"></image>
        <text class="menu-title">成员管理</text>
        <text class="menu-desc">管理团员、审批申请</text>
        <image class="menu-arrow" src="/images/arrow.png"></image>
      </view>
      <view class="menu-item" bindtap="goToPage" data-path="/pages/admin-activities/admin-activities">
        <image class="menu-icon" src="/images/activity.png"></image>
        <text class="menu-title">活动管理</text>
        <text class="menu-desc">创建、编辑活动</text>
        <image class="menu-arrow" src="/images/arrow.png"></image>
      </view>
      <view class="menu-item" bindtap="goToPage" data-path="/pages/admin-products/admin-products">
        <image class="menu-icon" src="/images/product.png"></image>
        <text class="menu-title">商品管理</text>
        <text class="menu-desc">管理周边商品</text>
        <image class="menu-arrow" src="/images/arrow.png"></image>
      </view>
      <view class="menu-item" bindtap="goToPage" data-path="/pages/admin-orders/admin-orders">
        <image class="menu-icon" src="/images/order.png"></image>
        <text class="menu-title">订单管理</text>
        <text class="menu-desc">处理订单发货</text>
        <image class="menu-arrow" src="/images/arrow.png"></image>
      </view>
    </view>
  </view>
</view>