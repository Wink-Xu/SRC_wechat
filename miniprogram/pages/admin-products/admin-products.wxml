<!--pages/admin-products/admin-products.wxml-->
<view class="container">
  <!-- 商品列表 -->
  <view class="product-list">
    <view wx:if="{{loading && products.length === 0}}" class="loading-box">
      <text>加载中...</text>
    </view>

    <view wx:elif="{{products.length === 0}}" class="empty-box">
      <text class="empty-text">暂无商品</text>
    </view>

    <view class="product-card" wx:for="{{products}}" wx:key="_id">
      <image class="product-image" src="{{item.images[0] || item.image || '/images/default-product.png'}}"></image>
      <view class="product-info">
        <text class="product-name">{{item.name}}</text>
        <view class="product-price">
          <text wx:if="{{item.points_price}}">{{item.points_price}}积分</text>
          <text wx:if="{{item.cash_price}}"> 或¥{{item.cashPriceYuan}}</text>
        </view>
        <text class="product-stock">库存: {{item.stock}}</text>
      </view>
      <view class="product-status">
        <text class="status-tag {{item.status}}">{{item.statusText}}</text>
      </view>
      <view class="product-actions">
        <button class="btn btn-secondary btn-small" data-id="{{item._id}}" bindtap="editProduct">编辑</button>
        <button
          class="btn btn-small {{item.status === 'available' ? 'btn-error' : 'btn-primary'}}"
          data-id="{{item._id}}"
          data-status="{{item.status}}"
          bindtap="toggleStatus"
        >{{item.status === 'available' ? '下架' : '上架'}}</button>
      </view>
    </view>

    <view wx:if="{{loadingMore}}" class="loading-more">
      <text>加载更多...</text>
    </view>

    <view wx:if="{{!hasMore && products.length > 0}}" class="no-more">
      <text>没有更多了</text>
    </view>
  </view>

  <!-- 添加按钮 -->
  <view class="fab-btn" bindtap="showAddProduct">
    <text class="fab-icon">+</text>
  </view>

  <!-- 添加/编辑弹窗 -->
  <view class="modal-mask" wx:if="{{showAddModal}}">
    <view class="modal-content" catchtap="stopTap">
      <view class="modal-header">
        <text class="modal-title">{{editingId ? '编辑商品' : '添加商品'}}</text>
        <text class="modal-close" bindtap="closeModal">×</text>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">商品名称 *</text>
          <input class="form-input" placeholder="请输入商品名称" value="{{formData.name}}" data-field="name" bindinput="onInputChange" />
        </view>
        <view class="form-item">
          <text class="form-label">商品描述</text>
          <textarea class="form-textarea" placeholder="请输入商品描述" value="{{formData.description}}" data-field="description" bindinput="onInputChange"></textarea>
        </view>
        <view class="form-item">
          <text class="form-label">商品图片</text>
          <view class="image-upload">
            <!-- 图片预览网格 -->
            <view wx:if="{{formData.images.length > 0}}" class="image-preview-list">
              <view class="image-preview-item" wx:for="{{formData.images}}" wx:key="index">
                <image class="preview-image" src="{{item}}" mode="aspectFill" bindtap="previewImage" data-index="{{index}}"></image>
                <view class="image-delete" bindtap="deleteImage" data-index="{{index}}">×</view>
              </view>
            </view>
            <!-- 上传按钮 -->
            <view wx:if="{{formData.images.length < 9}}" class="upload-btn" bindtap="chooseImage">
              <view class="upload-add">
                <text class="upload-icon">+</text>
              </view>
            </view>
          </view>
        </view>
        <view class="form-item">
          <text class="form-label">积分价格</text>
          <input class="form-input" type="number" placeholder="积分兑换价格" value="{{formData.points_price}}" data-field="points_price" bindinput="onInputChange" />
        </view>
        <view class="form-item">
          <text class="form-label">现金价格(元)</text>
          <input class="form-input" type="digit" placeholder="现金购买价格" value="{{formData.cash_price}}" data-field="cash_price" bindinput="onInputChange" />
        </view>
        <view class="form-item">
          <text class="form-label">库存 *</text>
          <input class="form-input" type="number" placeholder="库存数量" value="{{formData.stock}}" data-field="stock" bindinput="onInputChange" />
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn btn-secondary" bindtap="closeModal">取消</button>
        <button class="btn btn-primary" bindtap="submitForm">保存</button>
      </view>
    </view>
  </view>
</view>