/* pages/admin-products/admin-products.wxss - On Running 极简风格 */

.container {
  min-height: 100vh;
  background: var(--background);
  padding-bottom: 120rpx;
}

.product-list {
  padding: 20rpx 30rpx;
}

.product-card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  border: 1rpx solid #F0F0F0;
}

.product-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.product-info {
  flex: 1;
  min-width: 200rpx;
}

.product-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1A1A1A;
  display: block;
  margin-bottom: 8rpx;
}

.product-price {
  font-size: 26rpx;
  color: #1A1A1A;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.product-stock {
  font-size: 24rpx;
  color: #999999;
}

.product-status {
  margin-left: 16rpx;
}

.status-tag {
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
  background: #F5F5F5;
  color: #666666;
}

.status-tag.available {
  background: #F5F5F5;
  color: #2E7D32;
}

.status-tag.unavailable {
  background: #F5F5F5;
  color: #F44336;
}

.product-actions {
  width: 100%;
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F5F5F5;
}

.btn-error {
  background: #FFFFFF;
  color: #F44336;
  border: 1rpx solid #F44336;
  border-radius: 32rpx;
  font-weight: 500;
}

/* 加载状态 */
.loading-box,
.loading-more {
  text-align: center;
  padding: 40rpx;
  color: #999999;
}

.no-more {
  text-align: center;
  padding: 30rpx;
  color: #999999;
  font-size: 24rpx;
}

.empty-box {
  text-align: center;
  padding: 60rpx;
}

.empty-text {
  color: #999999;
}

/* 悬浮按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background: #1A1A1A;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fab-icon {
  font-size: 48rpx;
  color: #FFFFFF;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-height: 80vh;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #1A1A1A;
}

.modal-close {
  font-size: 48rpx;
  color: #999999;
  line-height: 1;
}

.modal-body {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #1A1A1A;
  display: block;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  height: 80rpx;
  padding: 0 20rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1A1A1A;
  border: 1rpx solid transparent;
}

.form-input:focus {
  border-color: #1A1A1A;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  padding: 20rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1A1A1A;
  box-sizing: border-box;
  border: 1rpx solid transparent;
}

.form-textarea:focus {
  border-color: #1A1A1A;
}

.image-upload {
  width: 200rpx;
  height: 200rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #999999;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #F5F5F5;
}

.modal-footer .btn {
  flex: 1;
  background: #1A1A1A;
  color: #FFFFFF;
  border: none;
  border-radius: 32rpx;
  font-weight: 500;
}