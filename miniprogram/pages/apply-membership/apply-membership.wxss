/* pages/apply-membership/apply-membership.wxss - On Running 极简风格 */

.container {
  min-height: 100vh;
  background-color: #FFFFFF;
  padding: 40rpx;
}

.header {
  text-align: center;
  padding: 60rpx 0 40rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #000000;
  margin-bottom: 12rpx;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.desc {
  display: block;
  font-size: 26rpx;
  color: #999999;
}

.form-card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid #F0F0F0;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #000000;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.avatar-wrapper {
  display: flex;
  justify-content: center;
  margin-top: 8rpx;
}

.avatar-btn {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  background: #F5F5F5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: 1rpx solid #E0E0E0;
}

.avatar-btn text {
  font-size: 22rpx;
  color: #666666;
}

.avatar-preview {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.form-input {
  height: 92rpx;
  padding: 0 26rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #000000;
  border: 1rpx solid transparent;
}

.form-input:focus {
  border-color: #000000;
}

.form-input::placeholder {
  color: #999999;
}

.btn-submit {
  height: 92rpx;
  background: #000000;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  border-radius: 46rpx;
}

.btn-submit::after {
  border: none;
}

.tips {
  text-align: center;
  padding: 24rpx 0;
}

.tips text {
  font-size: 22rpx;
  color: #999999;
}
