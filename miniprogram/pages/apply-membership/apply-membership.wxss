/* pages/apply-membership/apply-membership.wxss */

.container {
  min-height: 100vh;
  background-color: #1A1A1A;
  padding: 40rpx;
}

.header {
  text-align: center;
  padding: 60rpx 0 40rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.desc {
  display: block;
  font-size: 26rpx;
  color: #8E8E8E;
}

.form-card {
  background: #2D2D2D;
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.avatar-wrapper {
  display: flex;
  justify-content: center;
  margin-top: 8rpx;
}

.avatar-btn {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  background: #3D3D3D;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: 3rpx solid #D4C4FF;
}

.avatar-btn text {
  font-size: 22rpx;
  color: #FFFFFF;
}

.avatar-preview {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.form-input {
  height: 92rpx;
  padding: 0 26rpx;
  background: #3D3D3D;
  border-radius: 18rpx;
  font-size: 30rpx;
  color: #FFFFFF;
  border: 2rpx solid transparent;
}

.form-input:focus {
  border-color: #D4C4FF;
}

.form-input::placeholder {
  color: #8E8E8E;
}

.btn-submit {
  height: 92rpx;
  background: #C8FF54;
  color: #1A1A1A;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  border-radius: 46rpx;
  box-shadow: 0 8rpx 24rpx rgba(200, 255, 84, 0.25);
}

.btn-submit::after {
  border: none;
}

.tips {
  text-align: center;
  padding: 24rpx 0;
}

.tips text {
  font-size: 22rpx;
  color: #8E8E8E;
}
