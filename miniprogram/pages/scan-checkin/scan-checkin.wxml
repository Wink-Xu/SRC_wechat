<!--pages/scan-checkin/scan-checkin.wxml-->
<view class="container">
  <view wx:if="{{loading}}" class="loading-box">
    <text>加载中...</text>
  </view>

  <block wx:elif="{{error}}">
    <!-- 错误状态 -->
    <view class="error-box">
      <text class="error-icon">⚠️</text>
      <text class="error-text">{{error}}</text>
      <button class="btn-back" bindtap="goBack">返回</button>
    </view>
  </block>

  <block wx:elif="{{activity}}">
    <!-- 活动信息卡片 -->
    <view class="activity-card">
      <view class="card-header">
        <text class="activity-title">{{activity.title}}</text>
      </view>

      <view class="activity-info">
        <view class="info-item">
          <text class="info-icon">⏰</text>
          <text class="info-text">{{activity.formattedTime}}</text>
        </view>
        <view class="info-item">
          <text class="info-icon">📍</text>
          <text class="info-text">{{activity.location}}</text>
        </view>
        <view class="info-item">
          <text class="info-icon">🏃</text>
          <text class="info-text">{{activity.runTypeText || '路跑'}}</text>
        </view>
        <view class="info-item">
          <text class="info-icon">🏆</text>
          <text class="info-text">完成可获得 {{activity.points}} 积分</text>
        </view>
      </view>
    </view>

    <!-- 签到状态 -->
    <view class="checkin-section">
      <block wx:if="{{hasCheckedIn}}">
        <!-- 已签到 -->
        <view class="checked-in-box">
          <text class="checked-icon">✅</text>
          <text class="checked-title">您已签到</text>
          <text class="checked-desc">活动结束后将自动获得 {{activity.points}} 积分</text>
        </view>
        <button class="btn-back" bindtap="goBack">返回</button>
      </block>

      <block wx:elif="{{!isRegistered}}">
        <!-- 未报名 -->
        <view class="not-registered-box">
          <text class="warning-icon">📋</text>
          <text class="warning-title">您未报名此活动</text>
          <text class="warning-desc">请先报名后再签到</text>
        </view>
        <button class="btn-primary" bindtap="goToRegister">去报名</button>
        <button class="btn-back" bindtap="goBack">返回</button>
      </block>

      <block wx:else>
        <!-- 未签到 -->
        <view class="checkin-box">
          <text class="checkin-title">活动签到</text>
          <text class="checkin-desc">确认签到后，活动结束时将获得 {{activity.points}} 积分</text>
        </view>

        <button class="btn-primary" bindtap="confirmCheckIn">
          确认签到
        </button>
        <button class="btn-back" bindtap="goBack">取消</button>
      </block>
    </view>
  </block>
</view>
