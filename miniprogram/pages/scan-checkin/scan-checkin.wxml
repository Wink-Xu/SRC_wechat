<!--pages/scan-checkin/scan-checkin.wxml-->
<view class="container">
  <view wx:if="{{loading}}" class="loading-box">
    <text>加载中...</text>
  </view>

  <block wx:elif="{{activity}}">
    <!-- 活动信息卡片 -->
    <view class="activity-card">
      <view class="card-header">
        <text class="activity-title">{{activity.title}}</text>
      </view>

      <view class="activity-info">
        <view class="info-item">
          <image class="info-icon" src="/images/time.png"></image>
          <text class="info-text">{{activity.formattedTime}}</text>
        </view>
        <view class="info-item">
          <image class="info-icon" src="/images/location.png"></image>
          <text class="info-text">{{activity.location}}</text>
        </view>
        <view class="info-item">
          <image class="info-icon" src="/images/user.png"></image>
          <text class="info-text">{{activity.runTypeText || '路跑'}}</text>
        </view>
        <view class="info-item">
          <image class="info-icon" src="/images/trophy.png"></image>
          <text class="info-text">完成可获得 {{activity.points}} 积分</text>
        </view>
      </view>
    </view>

    <!-- 签到状态 -->
    <view class="checkin-section">
      <block wx:if="{{hasCheckedIn}}">
        <!-- 已签到 -->
        <view class="checked-in-box">
          <image class="checked-icon" src="/images/check-circle.png"></image>
          <text class="checked-title">您已签到</text>
          <text class="checked-time">签到时间：{{checkInTime}}</text>
        </view>
      </block>

      <block wx:else>
        <!-- 未签到 -->
        <view class="checkin-box">
          <text class="checkin-title">确认参加此活动？</text>
          <text class="checkin-desc">签到成功后将获得活动积分</text>

          <button class="btn btn-primary btn-full" bindtap="confirmCheckIn">
            确认签到
          </button>
          <button class="btn btn-secondary btn-full" bindtap="goBack">
            取消
          </button>
        </view>
      </block>
    </view>
  </block>
</view>
