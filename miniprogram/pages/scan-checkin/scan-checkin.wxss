/* pages/scan-checkin/scan-checkin.wxss - On Running 极简风格 */

page {
  background: var(--background);
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  padding: 40rpx;
}

.loading-box {
  text-align: center;
  padding: 120rpx;
  color: var(--text-secondary);
  font-size: 28rpx;
}

/* ========== 活动卡片 - 极简设计 ========== */
.activity-card {
  background: var(--background);
  border-radius: 12rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid var(--divider);
}

.card-header {
  margin-bottom: 28rpx;
}

.activity-title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-primary);
  display: block;
  line-height: 1.4;
  letter-spacing: -0.5rpx;
}

.activity-info {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.info-item {
  display: flex;
  align-items: center;
}

.info-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
  opacity: 1;
}

.info-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* ========== 签到区域 - 极简风格 ========== */
.checkin-section {
  background: var(--background);
  border-radius: 12rpx;
  padding: 48rpx 40rpx;
  border: 1rpx solid var(--divider);
}

.checkin-box {
  text-align: center;
}

.checkin-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  letter-spacing: -0.5rpx;
}

.checkin-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-hint);
  margin-bottom: 48rpx;
  line-height: 1.6;
}

/* ========== 已签到样式 ========== */
.checked-in-box {
  text-align: center;
  padding: 32rpx 0;
}

.checked-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 28rpx;
}

.checked-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--success);
  margin-bottom: 16rpx;
  letter-spacing: -0.5rpx;
}

.checked-time {
  display: block;
  font-size: 26rpx;
  color: var(--text-hint);
  font-weight: 500;
}

/* ========== 按钮 - 瑞士风格 ========== */
.btn {
  height: 100rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  margin-bottom: 20rpx;
  letter-spacing: -0.5rpx;
  transition: all 0.2s ease;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: var(--primary);
  color: var(--background);
}

.btn-primary:active {
  opacity: 0.9;
}

.btn-secondary {
  background: var(--surface);
  color: var(--text-primary);
}

.btn-secondary:active {
  background: var(--accent);
}

.btn-full {
  width: 100%;
}
