/* pages/scan-checkin/scan-checkin.wxss */
page {
  background: #F8F9FA;
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  padding: 30rpx;
}

.loading-box {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

/* 活动卡片 */
.activity-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.card-header {
  margin-bottom: 24rpx;
}

.activity-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  display: block;
  line-height: 1.4;
}

.activity-info {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-item {
  display: flex;
  align-items: center;
}

.info-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
  opacity: 0.7;
}

.info-text {
  font-size: 28rpx;
  color: #666;
}

/* 签到区域 */
.checkin-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.checkin-box {
  text-align: center;
}

.checkin-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.checkin-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

/* 已签到样式 */
.checked-in-box {
  text-align: center;
  padding: 20rpx 0;
}

.checked-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
}

.checked-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #4CAF50;
  margin-bottom: 12rpx;
}

.checked-time {
  display: block;
  font-size: 24rpx;
  color: #999;
}

/* 按钮 */
.btn {
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  margin-bottom: 20rpx;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #9C27B0, #7B1FA2);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(156,39,176,0.4);
}

.btn-secondary {
  background: #f5f5f5;
  color: #333;
}

.btn-full {
  width: 100%;
}
