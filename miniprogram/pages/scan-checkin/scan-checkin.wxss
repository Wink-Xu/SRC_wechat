/* pages/scan-checkin/scan-checkin.wxss - On Running 极简风格 */
page {
  background: var(--background);
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  padding: 30rpx;
}

.loading-box {
  text-align: center;
  padding: 100rpx;
  color: #999999;
}

/* 错误状态 */
.error-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 30rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.error-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}

/* 活动卡片 */
.activity-card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid #F0F0F0;
}

.card-header {
  margin-bottom: 24rpx;
}

.activity-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #1A1A1A;
  display: block;
  line-height: 1.4;
}

.activity-info {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-item {
  display: flex;
  align-items: center;
}

.info-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.info-text {
  font-size: 28rpx;
  color: #666666;
}

/* 签到区域 */
.checkin-section {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 40rpx 30rpx;
  border: 1rpx solid #F0F0F0;
}

.checkin-box {
  text-align: center;
}

.checkin-title {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 12rpx;
}

.checkin-desc {
  display: block;
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 40rpx;
}

/* 已签到样式 */
.checked-in-box {
  text-align: center;
  padding: 20rpx 0;
}

.checked-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  display: block;
}

.checked-title {
  display: block;
  font-size: 36rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 12rpx;
}

.checked-desc {
  display: block;
  font-size: 26rpx;
  color: #999999;
}

/* 未报名样式 */
.not-registered-box {
  text-align: center;
  padding: 20rpx 0;
}

.warning-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  display: block;
}

.warning-title {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 12rpx;
}

.warning-desc {
  display: block;
  font-size: 26rpx;
  color: #999999;
}

/* 按钮 */
.btn-primary {
  width: 100%;
  height: 96rpx;
  background: #1A1A1A;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary::after {
  border: none;
}

.btn-back {
  width: 100%;
  height: 96rpx;
  background: #F5F5F5;
  color: #666666;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-back::after {
  border: none;
}
