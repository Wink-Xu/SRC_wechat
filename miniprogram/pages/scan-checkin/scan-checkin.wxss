/* pages/scan-checkin/scan-checkin.wxss - On Running 极简风格 */
page {
  background: var(--background);
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  padding: 30rpx;
}

.loading-box {
  text-align: center;
  padding: 100rpx;
  color: #999999;
}

/* 活动卡片 */
.activity-card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid #F0F0F0;
}

.card-header {
  margin-bottom: 24rpx;
}

.activity-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #1A1A1A;
  display: block;
  line-height: 1.4;
}

.activity-info {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-item {
  display: flex;
  align-items: center;
}

.info-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
  opacity: 0.7;
}

.info-text {
  font-size: 28rpx;
  color: #666666;
}

/* 签到区域 */
.checkin-section {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 40rpx 30rpx;
  border: 1rpx solid #F0F0F0;
}

.checkin-box {
  text-align: center;
}

.checkin-title {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 12rpx;
}

.checkin-desc {
  display: block;
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 40rpx;
}

/* 已签到样式 */
.checked-in-box {
  text-align: center;
  padding: 20rpx 0;
}

.checked-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.7;
}

.checked-title {
  display: block;
  font-size: 36rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 12rpx;
}

.checked-time {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

/* 按钮 */
.btn {
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  margin-bottom: 20rpx;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: #1A1A1A;
  color: #FFFFFF;
}

.btn-secondary {
  background: #F5F5F5;
  color: #1A1A1A;
}

.btn-full {
  width: 100%;
}
