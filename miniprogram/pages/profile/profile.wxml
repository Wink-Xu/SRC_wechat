<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户信息 -->
  <view class="user-section">
    <view class="user-info" wx:if="{{isLoggedIn}}">
      <image class="avatar" src="{{userInfo.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      <view class="user-text">
        <text class="nickname">{{userInfo.nickname}}</text>
        <view class="user-meta">
          <text class="role-tag" wx:if="{{isLeader}}">团长</text>
          <text class="role-tag" wx:elif="{{isAdmin}}">管理员</text>
          <text class="role-tag member" wx:elif="{{userInfo.status === 'approved'}}">团员</text>
          <text class="role-tag pending" wx:else>待审批</text>
        </view>
      </view>
      <view class="points-box">
        <text class="points-value">{{points}}</text>
        <text class="points-label">积分</text>
      </view>
    </view>
    <view class="login-prompt" wx:else>
      <image class="default-avatar" src="/images/default-avatar.png"></image>
      <button class="btn btn-primary btn-small" bindtap="goToLogin">立即登录</button>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section" wx:if="{{isLoggedIn}}">
    <view class="menu-group">
      <view
        class="menu-item"
        wx:for="{{menuItems}}"
        wx:key="title"
        bindtap="goToPage"
        data-path="{{item.path}}"
      >
        <image class="menu-icon" src="/images/{{item.icon}}.png"></image>
        <text class="menu-title">{{item.title}}</text>
        <image class="menu-arrow" src="/images/arrow.png"></image>
      </view>
    </view>

    <!-- 管理员菜单 -->
    <view class="menu-group" wx:if="{{isAdmin}}">
      <view class="group-title">管理功能</view>
      <view
        class="menu-item"
        wx:for="{{adminMenus}}"
        wx:key="title"
        bindtap="goToPage"
        data-path="{{item.path}}"
      >
        <image class="menu-icon" src="/images/{{item.icon}}.png"></image>
        <text class="menu-title">{{item.title}}</text>
        <image class="menu-arrow" src="/images/arrow.png"></image>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="menu-group">
      <view class="menu-item logout" bindtap="handleLogout">
        <text class="logout-text">退出登录</text>
      </view>
    </view>

    <!-- Mock 模式调试入口 -->
    <view class="menu-group" wx:if="{{useMock}}">
      <view class="menu-item" bindtap="goToDebug">
        <image class="menu-icon" src="/images/user.png"></image>
        <text class="menu-title">角色切换（Mock）</text>
        <image class="menu-arrow" src="/images/arrow.png"></image>
      </view>
    </view>
  </view>
</view>