/* pages/profile/profile.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 用户区域 */
.user-section {
  background: linear-gradient(135deg, #9C27B0, #7B1FA2);
  padding: 60rpx 30rpx;
  color: #fff;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.user-text {
  flex: 1;
  margin-left: 24rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.user-meta {
  display: flex;
  align-items: center;
}

.role-tag {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.2);
}

.role-tag.member {
  background: rgba(255, 255, 255, 0.3);
}

.role-tag.pending {
  background: rgba(255, 152, 0, 0.5);
}

.points-box {
  text-align: center;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
}

.points-value {
  font-size: 40rpx;
  font-weight: 700;
  display: block;
}

.points-label {
  font-size: 22rpx;
  opacity: 0.8;
}

.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.default-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
  opacity: 0.8;
}

/* 菜单区域 */
.menu-section {
  padding: 20rpx 30rpx;
}

.menu-group {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.group-title {
  font-size: 26rpx;
  color: #999;
  padding: 20rpx 24rpx 12rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 20rpx;
}

.menu-title {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.5;
}

.menu-item.logout {
  justify-content: center;
}

.logout-text {
  font-size: 30rpx;
  color: #f44336;
}