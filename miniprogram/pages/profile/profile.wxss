/* pages/profile/profile.wxss - On Running 极简风格 */

page {
  background: var(--background);
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  background: var(--background);
  padding-bottom: 40rpx;
}

/* 头部用户信息 */
.header-section {
  padding: 60rpx 30rpx 40rpx;
  background: #FFFFFF;
}

.header-top {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #F5F5F5;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: 40rpx;
  font-weight: 600;
  color: #1A1A1A;
  display: block;
  margin-bottom: 16rpx;
}

.openid-text {
  font-size: 20rpx;
  color: #999999;
  display: block;
  margin-bottom: 16rpx;
  word-break: break-all;
}

.role-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.role-tag {
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  background: #F5F5F5;
  color: #666666;
  font-weight: 500;
}

.role-tag.member {
  background: #1A1A1A;
  color: #FFFFFF;
}

.role-tag.pending {
  background: #F5F5F0;
  color: #CC7722;
}

.role-tag.guest {
  background: #F5F5F5;
  color: #999999;
}

/* 数据统计卡片 */
.stats-card {
  margin: 0 30rpx 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  border: 1rpx solid #F0F0F0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.stat-label {
  font-size: 26rpx;
  color: #999999;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #F0F0F0;
}

/* Slogan */
.slogan-section {
  padding: 0 30rpx 20rpx;
}

.slogan-text {
  font-size: 26rpx;
  color: var(--brand-pink);
  font-weight: 600;
}

/* 功能菜单卡片 */
.menu-card {
  margin: 0 30rpx 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 40rpx 20rpx;
  border: 1rpx solid #F0F0F0;
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.menu-grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.menu-grid-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-grid-title {
  font-size: 24rpx;
  color: #1A1A1A;
  text-align: center;
}

/* 申请/待审批提示卡片 */
.prompt-card {
  margin: 0 30rpx 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  border: 1rpx solid #F0F0F0;
}

.prompt-card.pending {
  background: #F5F5F0;
  border: 1rpx solid #E5E5E0;
}

.prompt-text {
  font-size: 28rpx;
  color: #333333;
  text-align: center;
}

.prompt-sub {
  font-size: 24rpx;
  color: #666666;
}

.btn-prompt {
  background: #1A1A1A;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  padding: 16rpx 64rpx;
  border-radius: 32rpx;
  border: none;
}

.btn-prompt::after {
  border: none;
}

/* 管理员菜单 */
.admin-section {
  padding: 0 30rpx 20rpx;
}

.section-title {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 16rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.admin-section .menu-grid {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 40rpx 20rpx;
  border: 1rpx solid #F0F0F0;
  gap: 24rpx;
}

/* 退出登录 */
.logout-section {
  padding: 0 30rpx 20rpx;
}

.btn-logout {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  text-align: center;
  border: 1rpx solid #F0F0F0;
}

.logout-text {
  font-size: 30rpx;
  color: #F44336;
  font-weight: 600;
}

/* 跑团介绍卡片 */
.intro-card {
  margin: 0 30rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  border: 1rpx solid #F0F0F0;
}

.intro-logo {
  width: 200rpx;
  height: 120rpx;
}

.intro-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 2;
  text-align: justify;
  font-weight: 600;
  text-indent: 2em;
}

/* 登录遮罩 */
.login-overlay {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.95);
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: center;
  border-top: 1rpx solid #F0F0F0;
}

.btn-login {
  background: #1A1A1A;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx 80rpx;
  border-radius: 48rpx;
  border: none;
}

.btn-login::after {
  border: none;
}

/* Mock 调试入口 */
.debug-section {
  padding: 0 30rpx 20rpx;
}

.btn-debug {
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 28rpx;
  text-align: center;
}

.btn-debug text {
  font-size: 26rpx;
  color: #999999;
}

.btn-test-panel {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.btn-test-panel text {
  color: #FFFFFF;
  font-weight: 500;
}
