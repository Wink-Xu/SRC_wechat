/* pages/profile/profile.wxss - On Running 极简风格 */

.container {
  min-height: 100vh;
  background: #FFFFFF;
}

/* 用户区域 - 极简白色背景 */
.user-section {
  background: #FFFFFF;
  padding: 60rpx 30rpx;
  color: #000000;
  border-bottom: 1rpx solid #F0F0F0;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 2rpx solid #E0E0E0;
}

.user-text {
  flex: 1;
  margin-left: 24rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
  color: #000000;
}

.user-meta {
  display: flex;
  align-items: center;
}

.role-tag {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background: #F5F5F5;
  color: #666666;
  font-weight: 600;
}

.role-tag.member {
  background: #000000;
  color: #FFFFFF;
}

.role-tag.pending {
  background: #F5F5F0;
  color: #CC7722;
}

.role-tag.guest {
  background: #F5F5F5;
  color: #999999;
}

/* 申请入团提示 */
.apply-prompt {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.apply-text {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.btn-apply {
  background: #000000;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  padding: 16rpx 48rpx;
  border-radius: 32rpx;
  border: none;
}

.btn-apply::after {
  border: none;
}

/* 待审批提示 */
.pending-prompt {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #F5F5F0;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.pending-text {
  font-size: 26rpx;
  color: #000000;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.pending-sub {
  font-size: 24rpx;
  color: #666666;
}

.points-box {
  text-align: center;
  padding: 16rpx 24rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  margin-top: 16rpx;
}

.points-value {
  font-size: 40rpx;
  font-weight: 800;
  display: block;
  color: #000000;
}

.points-label {
  font-size: 22rpx;
  color: #999999;
}

.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.default-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

/* 菜单区域 */
.menu-section {
  padding: 20rpx 30rpx;
}

.menu-group {
  background: #FFFFFF;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  border: 1rpx solid #F0F0F0;
}

.group-title {
  font-size: 26rpx;
  color: #999999;
  padding: 20rpx 24rpx 12rpx;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 20rpx;
}

.menu-title {
  flex: 1;
  font-size: 30rpx;
  color: #000000;
  font-weight: 500;
}

.menu-arrow {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.5;
}

.menu-item.logout {
  justify-content: center;
}

.logout-text {
  font-size: 30rpx;
  color: #F44336;
  font-weight: 600;
}
