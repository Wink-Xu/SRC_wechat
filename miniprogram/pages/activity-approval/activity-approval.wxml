<!--pages/activity-approval/activity-approval.wxml-->
<view class="container">
  <view wx:if="{{loading}}" class="loading-box">
    <text>加载中...</text>
  </view>

  <block wx:elif="{{activity}}">
    <!-- 活动信息 -->
    <view class="activity-header">
      <text class="activity-title">{{activity.title}}</text>
      <view class="activity-info">
        <text class="info-text">活动时间：{{activity.formattedTime}}</text>
        <text class="info-text">已报名：{{activity.registered_count || 0}}人</text>
      </view>
    </view>

    <!-- 提示信息 -->
    <view class="tips-card">
      <text class="tips-title">审批说明</text>
      <text class="tips-text">1. 请勾选实际参加活动的团员</text>
      <text class="tips-text">2. 确认参加的团员将获得 {{activity.points}} 积分</text>
      <text class="tips-text">3. 活动结束后才能上传照片</text>
    </view>

    <!-- 参加人员选择 -->
    <view class="participants-section">
      <view class="section-header">
        <text class="section-title">参加人员确认</text>
        <view class="batch-actions">
          <text class="batch-btn" bindtap="selectAll">全选</text>
          <text class="batch-btn" bindtap="deselectAll">全不选</text>
        </view>
      </view>

      <view class="participants-list">
        <view
          class="participant-item {{item.selected ? 'selected' : ''}}"
          wx:for="{{participants}}"
          wx:key="_id"
          bindtap="toggleParticipant"
          data-index="{{index}}"
        >
          <view class="checkbox {{item.selected ? 'checked' : ''}}">
            <image wx:if="{{item.selected}}" class="check-icon" src="/images/check.png"></image>
          </view>
          <image class="participant-avatar" src="{{item.avatar || '/images/default-avatar.png'}}"></image>
          <text class="participant-name">{{item.nickname}}</text>
          <text class="participant-points" wx:if="{{item.selected}}">+{{activity.points}}积分</text>
        </view>
      </view>
    </view>

    <!-- 活动照片上传 -->
    <view class="photos-section">
      <view class="section-header">
        <text class="section-title">活动照片</text>
      </view>
      <view class="photo-upload-area" bindtap="uploadPhotos">
        <image class="add-icon" src="/images/add.png"></image>
        <text class="add-text">点击上传照片</text>
      </view>
      <view class="photos-preview" wx:if="{{photos.length > 0}}">
        <view class="photo-item" wx:for="{{photos}}" wx:key="*this">
          <image class="photo-img" src="{{item}}" mode="aspectFill"></image>
        </view>
      </view>
    </view>

    <!-- 底部操作 -->
    <view class="footer-actions">
      <button class="btn btn-secondary" bindtap="cancel">取消</button>
      <button class="btn btn-primary" bindtap="submitApproval" disabled="{{selectedCount === 0}}">
        确认完成（{{selectedCount}}人参加）
      </button>
    </view>
  </block>
</view>
