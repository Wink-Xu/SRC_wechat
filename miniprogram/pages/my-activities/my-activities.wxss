/* pages/my-activities/my-activities.wxss */

page {
  background: #0a0a0a;
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  background: #0a0a0a;
  padding: 30rpx;
}

.loading-box {
  text-align: center;
  padding: 120rpx;
  color: #999999;
}

.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 30rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
  opacity: 0.3;
}

.empty-text {
  color: #999999;
  font-size: 28rpx;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.activity-card {
  background: #1a1a1a;
  border-radius: 16rpx;
  overflow: hidden;
}

.cover-image {
  width: 100%;
  height: 360rpx;
  overflow: hidden;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.activity-info {
  padding: 24rpx;
}

.activity-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.activity-meta {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.meta-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  filter: invert(1);
}

.meta-text {
  font-size: 26rpx;
  color: #999999;
}

.checkin-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  color: #1A1A1A;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  margin-top: 16rpx;
}
