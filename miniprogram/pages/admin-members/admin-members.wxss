/* pages/admin-members/admin-members.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 状态选项卡 */
.status-tabs {
  display: flex;
  background: #fff;
  padding: 20rpx 30rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #9C27B0;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #9C27B0;
  border-radius: 2rpx;
}

/* 成员列表 */
.member-list {
  padding: 20rpx 30rpx;
}

.member-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.member-info {
  display: flex;
  margin-bottom: 20rpx;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.member-text {
  flex: 1;
}

.member-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.member-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-right: 12rpx;
}

.role-tag {
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  background: #E8F5E9;
  color: #9C27B0;
}

.role-tag.admin {
  background: #E3F2FD;
  color: #2196F3;
}

.member-phone,
.member-time {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.member-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

/* 加载状态 */
.loading-box,
.loading-more {
  text-align: center;
  padding: 40rpx;
  color: #999;
}

.no-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 24rpx;
}

.empty-box {
  text-align: center;
  padding: 60rpx;
}

.empty-text {
  color: #999;
}