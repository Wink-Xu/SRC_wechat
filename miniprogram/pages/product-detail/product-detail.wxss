/* pages/product-detail/product-detail.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

.loading-box {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

/* 商品图片 */
.product-image {
  width: 100%;
  height: 600rpx;
}

/* 商品信息 */
.product-info {
  background: #fff;
  padding: 30rpx;
}

.product-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.product-price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.points-price {
  display: flex;
  align-items: baseline;
}

.points-price .price-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #FF9800;
}

.points-price .price-unit {
  font-size: 26rpx;
  color: #FF9800;
  margin-left: 8rpx;
}

.cash-price {
  display: flex;
  align-items: baseline;
  margin-left: 24rpx;
}

.cash-price .price-label {
  font-size: 26rpx;
  color: #999;
  margin-right: 8rpx;
}

.cash-price .price-value {
  font-size: 32rpx;
  color: #666;
}

.product-stock {
  font-size: 26rpx;
  color: #999;
}

/* 区块 */
.product-desc,
.quantity-section,
.pay-method-section,
.address-section {
  background: #fff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 数量选择 */
.quantity-control {
  display: flex;
  align-items: center;
}

.quantity-btn {
  width: 60rpx;
  height: 60rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #333;
}

.quantity-btn.disabled {
  color: #ccc;
}

.quantity-value {
  width: 100rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
}

/* 支付方式 */
.pay-methods {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.pay-method {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.pay-method.active {
  background: #E8F5E9;
  border-color: #9C27B0;
}

.method-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.method-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF9800;
}

.method-tip {
  font-size: 22rpx;
  color: #f44336;
  margin-left: 12rpx;
}

/* 收货地址 */
.address-info {
  display: flex;
  flex-direction: column;
}

.address-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.address-detail {
  font-size: 26rpx;
  color: #666;
}

.address-empty {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.address-empty text {
  font-size: 28rpx;
  color: #999;
}

.arrow {
  color: #ccc;
}

/* 底部操作 */
.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.total-info {
  flex: 1;
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 8rpx;
}

.total-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF9800;
}

.buy-btn {
  width: 240rpx;
  margin: 0;
}