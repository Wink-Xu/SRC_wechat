/* pages/product-detail/product-detail.wxss - On Running 极简风格 */

.container {
  min-height: 100vh;
  background: #FFFFFF;
  padding-bottom: 160rpx;
}

.loading-box {
  text-align: center;
  padding: 100rpx;
  color: #999999;
}

/* 商品图片 */
.product-image {
  width: 100%;
  height: 600rpx;
}

/* 商品信息 */
.product-info {
  background: #FFFFFF;
  padding: 30rpx;
}

.product-name {
  font-size: 36rpx;
  font-weight: 500;
  color: #1A1A1A;
  display: block;
  margin-bottom: 20rpx;
}

.product-price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.points-price {
  display: flex;
  align-items: baseline;
}

.points-price .price-value {
  font-size: 44rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.points-price .price-unit {
  font-size: 26rpx;
  color: #666666;
  margin-left: 8rpx;
}

.cash-price {
  display: flex;
  align-items: baseline;
  margin-left: 24rpx;
}

.cash-price .price-label {
  font-size: 26rpx;
  color: #999999;
  margin-right: 8rpx;
}

.cash-price .price-value {
  font-size: 32rpx;
  color: #666666;
}

.product-stock {
  font-size: 26rpx;
  color: #999999;
}

/* 区块 */
.product-desc,
.quantity-section,
.pay-method-section,
.address-section {
  background: #FFFFFF;
  margin-top: 20rpx;
  padding: 30rpx;
  border: 1rpx solid #F0F0F0;
  border-radius: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1A1A1A;
  display: block;
  margin-bottom: 20rpx;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

/* 数量选择 */
.quantity-control {
  display: flex;
  align-items: center;
}

.quantity-btn {
  width: 60rpx;
  height: 60rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #000000;
}

.quantity-btn.disabled {
  color: #CCCCCC;
}

.quantity-value {
  width: 100rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  color: #1A1A1A;
}

/* 支付方式 */
.pay-methods {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.pay-method {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  border: 1rpx solid #F0F0F0;
}

.pay-method.active {
  background: #F5F5F5;
  border-color: #000000;
}

.method-name {
  flex: 1;
  font-size: 28rpx;
  color: #1A1A1A;
}

.method-value {
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A1A;
}

.method-tip {
  font-size: 22rpx;
  color: #F44336;
  margin-left: 12rpx;
}

/* 收货地址 */
.address-info {
  display: flex;
  flex-direction: column;
}

.address-name {
  font-size: 30rpx;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}

.address-detail {
  font-size: 26rpx;
  color: #666666;
}

.address-empty {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.address-empty text {
  font-size: 28rpx;
  color: #999999;
}

.arrow {
  color: #CCCCCC;
}

/* 底部操作 */
.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  border-top: 1rpx solid #F0F0F0;
}

.total-info {
  flex: 1;
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 28rpx;
  color: #666666;
  margin-right: 8rpx;
}

.total-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.buy-btn {
  width: 240rpx;
  margin: 0;
  background: #1A1A1A;
  color: #FFFFFF;
  border: none;
  border-radius: 32rpx;
  font-weight: 500;
}