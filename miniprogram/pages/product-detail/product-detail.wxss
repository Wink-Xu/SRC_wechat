/* pages/product-detail/product-detail.wxss - On Running 极简风格 */

.container {
  min-height: 100vh;
  background: var(--background);
  padding-bottom: 160rpx;
}

.loading-box {
  text-align: center;
  padding: 100rpx;
  color: #999999;
}

/* 商品图片轮播 */
.product-swiper {
  width: 100%;
  height: 600rpx;
}

.product-image {
  width: 100%;
  height: 600rpx;
}

/* 商品信息 */
.product-info {
  background: #FFFFFF;
  padding: 30rpx;
}

.product-name {
  font-size: 36rpx;
  font-weight: 500;
  color: #1A1A1A;
  display: block;
  margin-bottom: 20rpx;
}

.product-price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.points-price {
  display: flex;
  align-items: baseline;
}

.points-price .price-value {
  font-size: 44rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.points-price .price-unit {
  font-size: 26rpx;
  color: #666666;
  margin-left: 8rpx;
}

.cash-price {
  display: flex;
  align-items: baseline;
  margin-left: 24rpx;
}

.cash-price .price-label {
  font-size: 26rpx;
  color: #999999;
  margin-right: 8rpx;
}

.cash-price .price-value {
  font-size: 32rpx;
  color: #666666;
}

.product-stock {
  font-size: 26rpx;
  color: #999999;
}

/* 区块 */
.product-desc {
  background: #FFFFFF;
  margin-top: 20rpx;
  padding: 30rpx;
  border: 1rpx solid #F0F0F0;
  border-radius: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1A1A1A;
  display: block;
  margin-bottom: 20rpx;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

/* 商品细节图片 */
.detail-images {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 20rpx;
}

.detail-image-item {
  width: 100%;
  border-radius: 12rpx;
  overflow: hidden;
}

.detail-image {
  width: 100%;
  display: block;
}

/* 弹窗中的支付方式 */
.pay-methods {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.pay-method {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
}

.pay-method.active {
  border: 2rpx solid #1A1A1A;
}

.method-name {
  font-size: 28rpx;
  color: #1A1A1A;
}

.method-value {
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A1A;
}

.method-tip {
  font-size: 22rpx;
  color: #F44336;
}

/* 收货地址 */
.address-info {
  display: flex;
  flex-direction: column;
}

.address-name {
  font-size: 30rpx;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}

.address-detail {
  font-size: 26rpx;
  color: #666666;
}

.address-empty {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.address-empty text {
  font-size: 28rpx;
  color: #999999;
}

.arrow {
  color: #CCCCCC;
}

/* 底部操作 */
.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.btn-contact {
  width: 160rpx;
  height: 88rpx;
  margin: 0;
  padding: 0;
  background: #F5F5F5;
  color: #1A1A1A;
  border: none;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.btn-contact::after {
  border: none;
}

.buy-btn {
  flex: 1;
  height: 88rpx;
  margin: 0;
  background: #1A1A1A;
  color: #FFFFFF;
  border: none;
  border-radius: 32rpx;
  font-weight: 500;
}

/* 购买确认弹窗 */
.buy-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.buy-modal.show {
  opacity: 1;
  visibility: visible;
}

.buy-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.buy-content {
  position: relative;
  width: 100%;
  max-height: 85vh;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 30rpx 30rpx;
  overflow-y: auto;
  box-sizing: border-box;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.buy-modal.show .buy-content {
  transform: translateY(0);
}

.buy-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.buy-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.buy-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  border-radius: 50%;
  font-size: 40rpx;
  color: #666666;
}

.buy-product {
  display: flex;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
  gap: 24rpx;
}

.buy-product-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  object-fit: cover;
  flex-shrink: 0;
}

.buy-product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.buy-product-name {
  font-size: 28rpx;
  color: #1A1A1A;
  font-weight: 500;
  display: block;
}

.buy-product-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.buy-section {
  padding: 30rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.buy-section:last-child {
  border-bottom: none;
}

.buy-section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #999999;
  display: block;
  margin-bottom: 20rpx;
}

/* 尺码选择 */
.size-selector {
  display: flex;
  gap: 20rpx;
}

.size-item {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1A1A1A;
  font-weight: 500;
  border: 2rpx solid transparent;
}

.size-item.active {
  background: #1A1A1A;
  color: #FFFFFF;
}

/* 数量控制 */
.quantity-control {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.quantity-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  border-radius: 30rpx;
  font-size: 32rpx;
  color: #1A1A1A;
}

.quantity-btn.disabled {
  opacity: 0.3;
}

.quantity-value {
  font-size: 32rpx;
  font-weight: 500;
  color: #1A1A1A;
  min-width: 60rpx;
  text-align: center;
}

.buy-footer {
  display: flex;
  gap: 20rpx;
  padding-top: 30rpx;
}

.buy-cancel-btn,
.buy-confirm-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.buy-cancel-btn {
  background: #F5F5F5;
  color: #666666;
}

.buy-confirm-btn {
  background: #1A1A1A;
  color: #FFFFFF;
}